generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum EmploymentStatus {
  PROBATION
  ACTIVE
  ON_LEAVE
  INACTIVE
  TERMINATED
}

enum Gender {
  MALE
  FEMALE
  OTHER
  UNDISCLOSED
}

enum LeaveRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum ApprovalStepType {
  MANAGER
  HR
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  SKIPPED
}

enum AttendanceStatus {
  CHECKED_IN
  COMPLETED
  ABSENT
  MANUAL_ADJUSTED
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
  ARCHIVED
}

enum ProjectPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ProjectHealthStatus {
  ON_TRACK
  AT_RISK
  DELAYED
}

enum ProjectAssignmentStatus {
  ACTIVE
  ENDED
}

enum MilestoneStatus {
  PENDING
  IN_PROGRESS
  DONE
  OVERDUE
}

enum PayrollPeriodStatus {
  DRAFT
  CALCULATING
  APPROVED
  PAID
  CANCELLED
}

enum SalaryType {
  MONTHLY
  DAILY
  HOURLY
}

enum SalaryComponentType {
  EARNING
  DEDUCTION
}

enum SalaryCalculationType {
  FIXED
  FORMULA
  MANUAL
}

enum PayrollRecordStatus {
  DRAFT
  APPROVED
  PAID
  VOID
}

enum PayrollItemSourceType {
  BASE
  ALLOWANCE
  BONUS
  ATTENDANCE
  LEAVE
  MANUAL
  TAX
  INSURANCE
}

enum PayrollAdjustmentType {
  BONUS
  DEDUCTION
  ADVANCE
  REIMBURSEMENT
}

enum PayrollAdjustmentStatus {
  PENDING
  APPROVED
  REJECTED
  APPLIED
}

enum NotificationType {
  LEAVE_REQUEST_CREATED
  LEAVE_REQUEST_APPROVED
  LEAVE_REQUEST_REJECTED
  LEAVE_REQUEST_NEEDS_HR_REVIEW
  PROJECT_ASSIGNED
  PAYROLL_READY
  GENERAL
}

enum AuditEntityType {
  EMPLOYEE
  EMPLOYEE_PROFILE
  DEPARTMENT
  JOB_TITLE
  LEAVE_TYPE
  LEAVE_REQUEST
  LEAVE_REQUEST_APPROVAL
  ATTENDANCE
  PROJECT
  PROJECT_ASSIGNMENT
  PROJECT_MILESTONE
  PAYROLL_PERIOD
  EMPLOYEE_COMPENSATION
  SALARY_COMPONENT
  EMPLOYEE_SALARY_COMPONENT
  PAYROLL_RECORD
  PAYROLL_RECORD_ITEM
  PAYROLL_ADJUSTMENT
  USER
  USER_ROLE
  AUTH_TOKEN
  USER_SESSION
  NOTIFICATION
}

enum AuditActionType {
  CREATE
  UPDATE
  DEACTIVATE
  APPROVE
  REJECT
  CHECK_IN
  CHECK_OUT
  ASSIGN
  REMOVE
  STATUS_CHANGE
  LOGIN
  LOGOUT
  PASSWORD_SET
  PASSWORD_RESET
}

enum AccountStatus {
  PENDING
  ACTIVE
  LOCKED
  DISABLED
}

enum AuthTokenType {
  ACCOUNT_SETUP
  PASSWORD_RESET
}

model Department {
  id             String  @id @default(cuid()) @db.VarChar(30)
  name           String  @unique @db.VarChar(191)
  description    String? @db.Text
  headEmployeeId String? @map("head_employee_id") @db.VarChar(30)
  isActive       Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  headEmployee Employee?  @relation("DepartmentHead", fields: [headEmployeeId], references: [id], onDelete: SetNull)
  employees    Employee[] @relation("EmployeeDepartment")

  @@index([headEmployeeId])
  @@index([isActive])
  @@map("departments")
}

model JobTitle {
  id          String  @id @default(cuid()) @db.VarChar(30)
  code        String? @unique @db.VarChar(50)
  name        String  @unique @db.VarChar(191)
  description String? @db.Text
  isActive    Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  employees Employee[] @relation("EmployeeJobTitle")

  @@index([isActive])
  @@map("job_titles")
}

model Employee {
  id           String  @id @default(cuid()) @db.VarChar(30)
  employeeCode String? @unique @map("employee_code") @db.VarChar(50)
  fullName     String  @map("full_name") @db.VarChar(191)
  workEmail    String  @unique @map("work_email") @db.VarChar(191)
  phoneNumber  String? @map("phone_number") @db.VarChar(30)

  departmentId String? @map("department_id") @db.VarChar(30)
  jobTitleId   String? @map("job_title_id") @db.VarChar(30)
  managerId    String? @map("manager_id") @db.VarChar(30)

  hireDate           DateTime         @map("hire_date") @db.Date
  employmentStatus   EmploymentStatus @default(ACTIVE) @map("employment_status")
  isActive           Boolean          @default(true) @map("is_active")
  deactivatedAt      DateTime?        @map("deactivated_at")
  deactivationReason String?          @map("deactivation_reason") @db.Text

  avatarUrl String? @map("avatar_url") @db.VarChar(2048)
  notes     String? @db.Text

  createdByUserId String? @map("created_by_user_id") @db.VarChar(30)
  updatedByUserId String? @map("updated_by_user_id") @db.VarChar(30)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  department Department? @relation("EmployeeDepartment", fields: [departmentId], references: [id], onDelete: SetNull)
  jobTitle   JobTitle?   @relation("EmployeeJobTitle", fields: [jobTitleId], references: [id], onDelete: SetNull)

  manager      Employee?  @relation("EmployeeManager", fields: [managerId], references: [id], onDelete: SetNull)
  subordinates Employee[] @relation("EmployeeManager")

  headedDepartments   Department[]                @relation("DepartmentHead")
  profile             EmployeeProfile?
  leaveRequests       LeaveRequest[]              @relation("LeaveRequester")
  leaveApprovals      LeaveRequestApproval[]      @relation("LeaveApprover")
  attendanceRecords   AttendanceRecord[]
  projectAssignments  EmployeeProjectAssignment[]
  managedProjects     Project[]                   @relation("ProjectManager")
  milestoneOwnerships ProjectMilestone[]          @relation("MilestoneOwner")
  compensations       EmployeeCompensation[]
  salaryComponents    EmployeeSalaryComponent[]
  payrollRecords      PayrollRecord[]
  payrollAdjustments  PayrollAdjustment[]

  user User? @relation("EmployeeUser")

  createdByUser User? @relation("EmployeeCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUser User? @relation("EmployeeUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@index([fullName])
  @@index([departmentId])
  @@index([jobTitleId])
  @@index([managerId])
  @@index([employmentStatus, isActive])
  @@index([createdByUserId])
  @@index([updatedByUserId])
  @@map("employees")
}

model EmployeeProfile {
  id         String @id @default(cuid()) @db.VarChar(30)
  employeeId String @unique @map("employee_id") @db.VarChar(30)

  dateOfBirth DateTime? @map("date_of_birth") @db.Date
  gender      Gender?

  addressLine1 String? @map("address_line_1") @db.VarChar(255)
  addressLine2 String? @map("address_line_2") @db.VarChar(255)
  ward         String? @db.VarChar(100)
  district     String? @db.VarChar(100)
  city         String? @db.VarChar(100)
  province     String? @db.VarChar(100)
  country      String? @db.VarChar(100)
  postalCode   String? @map("postal_code") @db.VarChar(20)

  emergencyContactName         String? @map("emergency_contact_name") @db.VarChar(191)
  emergencyContactRelationship String? @map("emergency_contact_relationship") @db.VarChar(100)
  emergencyContactPhone        String? @map("emergency_contact_phone") @db.VarChar(30)
  emergencyContactEmail        String? @map("emergency_contact_email") @db.VarChar(191)

  bankName          String? @map("bank_name") @db.VarChar(191)
  bankAccountNumber String? @map("bank_account_number") @db.VarChar(100)
  bankAccountHolder String? @map("bank_account_holder") @db.VarChar(191)
  bankBranch        String? @map("bank_branch") @db.VarChar(191)

  taxCode String? @map("tax_code") @db.VarChar(100)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("employee_profiles")
}

model LeaveType {
  id          String  @id @default(cuid()) @db.VarChar(30)
  code        String? @unique @db.VarChar(50)
  name        String  @unique @db.VarChar(191)
  description String? @db.Text
  isPaid      Boolean @default(true) @map("is_paid")
  isActive    Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  leaveRequests LeaveRequest[]

  @@index([isActive])
  @@map("leave_types")
}

model LeaveRequest {
  id          String @id @default(cuid()) @db.VarChar(30)
  employeeId  String @map("employee_id") @db.VarChar(30)
  leaveTypeId String @map("leave_type_id") @db.VarChar(30)

  startDate DateTime @map("start_date") @db.Date
  endDate   DateTime @map("end_date") @db.Date
  totalDays Decimal  @map("total_days") @db.Decimal(5, 2)
  reason    String?  @db.Text

  status      LeaveRequestStatus @default(PENDING)
  currentStep ApprovalStepType?  @map("current_step")

  submittedAt     DateTime  @default(now()) @map("submitted_at")
  finalApprovedAt DateTime? @map("final_approved_at")
  rejectedAt      DateTime? @map("rejected_at")
  rejectionReason String?   @map("rejection_reason") @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  employee  Employee  @relation("LeaveRequester", fields: [employeeId], references: [id], onDelete: Restrict)
  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id], onDelete: Restrict)

  approvals LeaveRequestApproval[]

  @@index([employeeId, status])
  @@index([leaveTypeId])
  @@index([startDate, endDate])
  @@map("leave_requests")
}

model LeaveRequestApproval {
  id                 String @id @default(cuid()) @db.VarChar(30)
  leaveRequestId     String @map("leave_request_id") @db.VarChar(30)
  approverEmployeeId String @map("approver_employee_id") @db.VarChar(30)

  stepType  ApprovalStepType @map("step_type")
  stepOrder Int              @map("step_order")
  status    ApprovalStatus   @default(PENDING)

  comment  String?   @db.Text
  actionAt DateTime? @map("action_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  leaveRequest LeaveRequest @relation(fields: [leaveRequestId], references: [id], onDelete: Cascade)
  approver     Employee     @relation("LeaveApprover", fields: [approverEmployeeId], references: [id], onDelete: Restrict)

  @@unique([leaveRequestId, stepType])
  @@unique([leaveRequestId, stepOrder])
  @@index([approverEmployeeId, status])
  @@map("leave_request_approvals")
}

model AttendanceRecord {
  id         String @id @default(cuid()) @db.VarChar(30)
  employeeId String @map("employee_id") @db.VarChar(30)

  workDate         DateTime         @map("work_date") @db.Date
  checkInAt        DateTime?        @map("check_in_at")
  checkOutAt       DateTime?        @map("check_out_at")
  totalWorkMinutes Int?             @map("total_work_minutes")
  status           AttendanceStatus @default(CHECKED_IN)
  note             String?          @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Restrict)

  @@unique([employeeId, workDate])
  @@index([workDate])
  @@index([employeeId, status])
  @@map("attendance_records")
}

model Project {
  id          String  @id @default(cuid()) @db.VarChar(30)
  projectCode String? @unique @map("project_code") @db.VarChar(50)
  projectName String  @map("project_name") @db.VarChar(191)
  description String? @db.Text

  projectManagerEmployeeId String?              @map("project_manager_employee_id") @db.VarChar(30)
  status                   ProjectStatus        @default(PLANNING)
  priority                 ProjectPriority?
  healthStatus             ProjectHealthStatus? @map("health_status")
  progressPercent          Decimal              @default(0) @map("progress_percent") @db.Decimal(5, 2)

  startDate     DateTime? @map("start_date") @db.Date
  endDate       DateTime? @map("end_date") @db.Date
  actualEndDate DateTime? @map("actual_end_date") @db.Date

  budgetAmount Decimal? @map("budget_amount") @db.Decimal(18, 2)
  clientName   String?  @map("client_name") @db.VarChar(191)

  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  projectManager Employee?                   @relation("ProjectManager", fields: [projectManagerEmployeeId], references: [id], onDelete: SetNull)
  assignments    EmployeeProjectAssignment[]
  milestones     ProjectMilestone[]

  @@index([projectManagerEmployeeId])
  @@index([status, isActive])
  @@index([healthStatus])
  @@index([priority])
  @@index([startDate, endDate])
  @@map("projects")
}

model EmployeeProjectAssignment {
  id         String @id @default(cuid()) @db.VarChar(30)
  employeeId String @map("employee_id") @db.VarChar(30)
  projectId  String @map("project_id") @db.VarChar(30)

  roleInProject     String?                 @map("role_in_project") @db.VarChar(100)
  allocationPercent Decimal?                @map("allocation_percent") @db.Decimal(5, 2)
  joinedAt          DateTime                @map("joined_at") @db.Date
  leftAt            DateTime?               @map("left_at") @db.Date
  status            ProjectAssignmentStatus @default(ACTIVE)
  isBillable        Boolean                 @default(false) @map("is_billable")
  notes             String?                 @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  project  Project  @relation(fields: [projectId], references: [id], onDelete: Restrict)

  @@unique([employeeId, projectId, joinedAt])
  @@index([employeeId, status])
  @@index([projectId, status])
  @@map("employee_project_assignments")
}

model ProjectMilestone {
  id              String          @id @default(cuid()) @db.VarChar(30)
  projectId       String          @map("project_id") @db.VarChar(30)
  name            String          @db.VarChar(191)
  description     String?         @db.Text
  ownerEmployeeId String?         @map("owner_employee_id") @db.VarChar(30)
  dueDate         DateTime?       @map("due_date") @db.Date
  completedAt     DateTime?       @map("completed_at")
  status          MilestoneStatus @default(PENDING)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  project Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  owner   Employee? @relation("MilestoneOwner", fields: [ownerEmployeeId], references: [id], onDelete: SetNull)

  @@index([projectId, status])
  @@index([ownerEmployeeId])
  @@index([dueDate])
  @@map("project_milestones")
}

model PayrollPeriod {
  id         String              @id @default(cuid()) @db.VarChar(30)
  periodCode String              @unique @map("period_code") @db.VarChar(50)
  month      Int                 @db.UnsignedTinyInt
  year       Int                 @db.UnsignedSmallInt
  startDate  DateTime            @map("start_date") @db.Date
  endDate    DateTime            @map("end_date") @db.Date
  payDate    DateTime?           @map("pay_date") @db.Date
  status     PayrollPeriodStatus @default(DRAFT)

  lockedAt   DateTime? @map("locked_at")
  approvedAt DateTime? @map("approved_at")
  paidAt     DateTime? @map("paid_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  payrollRecords     PayrollRecord[]
  payrollAdjustments PayrollAdjustment[]

  @@unique([month, year])
  @@index([status])
  @@map("payroll_periods")
}

model EmployeeCompensation {
  id                   String     @id @default(cuid()) @db.VarChar(30)
  employeeId           String     @map("employee_id") @db.VarChar(30)
  salaryType           SalaryType @map("salary_type")
  baseSalary           Decimal    @map("base_salary") @db.Decimal(18, 2)
  standardWorkingDays  Int?       @map("standard_working_days")
  standardWorkingHours Decimal?   @map("standard_working_hours") @db.Decimal(5, 2)
  currency             String     @db.VarChar(10)
  effectiveFrom        DateTime   @map("effective_from") @db.Date
  effectiveTo          DateTime?  @map("effective_to") @db.Date
  isActive             Boolean    @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Restrict)

  @@unique([employeeId, effectiveFrom])
  @@index([employeeId, isActive])
  @@map("employee_compensations")
}

model SalaryComponent {
  id              String                @id @default(cuid()) @db.VarChar(30)
  code            String                @unique @db.VarChar(50)
  name            String                @unique @db.VarChar(191)
  componentType   SalaryComponentType   @map("component_type")
  calculationType SalaryCalculationType @map("calculation_type")
  isTaxable       Boolean               @default(false) @map("is_taxable")
  isInsurable     Boolean               @default(false) @map("is_insurable")
  isActive        Boolean               @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  employeeSalaryComponents EmployeeSalaryComponent[]
  payrollRecordItems       PayrollRecordItem[]

  @@index([componentType, isActive])
  @@map("salary_components")
}

model EmployeeSalaryComponent {
  id                String    @id @default(cuid()) @db.VarChar(30)
  employeeId        String    @map("employee_id") @db.VarChar(30)
  salaryComponentId String    @map("salary_component_id") @db.VarChar(30)
  amount            Decimal   @db.Decimal(18, 2)
  effectiveFrom     DateTime  @map("effective_from") @db.Date
  effectiveTo       DateTime? @map("effective_to") @db.Date
  isActive          Boolean   @default(true) @map("is_active")
  notes             String?   @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  employee        Employee        @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  salaryComponent SalaryComponent @relation(fields: [salaryComponentId], references: [id], onDelete: Restrict)

  @@unique([employeeId, salaryComponentId, effectiveFrom])
  @@index([employeeId, isActive])
  @@index([salaryComponentId])
  @@map("employee_salary_components")
}

model PayrollRecord {
  id              String @id @default(cuid()) @db.VarChar(30)
  payrollPeriodId String @map("payroll_period_id") @db.VarChar(30)
  employeeId      String @map("employee_id") @db.VarChar(30)

  baseSalary      Decimal             @map("base_salary") @db.Decimal(18, 2)
  workingDays     Decimal?            @map("working_days") @db.Decimal(5, 2)
  paidLeaveDays   Decimal?            @map("paid_leave_days") @db.Decimal(5, 2)
  unpaidLeaveDays Decimal?            @map("unpaid_leave_days") @db.Decimal(5, 2)
  grossSalary     Decimal             @map("gross_salary") @db.Decimal(18, 2)
  totalAllowances Decimal             @map("total_allowances") @db.Decimal(18, 2)
  totalBonus      Decimal             @map("total_bonus") @db.Decimal(18, 2)
  totalDeductions Decimal             @map("total_deductions") @db.Decimal(18, 2)
  netSalary       Decimal             @map("net_salary") @db.Decimal(18, 2)
  status          PayrollRecordStatus @default(DRAFT)

  generatedAt DateTime? @map("generated_at")
  approvedAt  DateTime? @map("approved_at")
  paidAt      DateTime? @map("paid_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  payrollPeriod PayrollPeriod @relation(fields: [payrollPeriodId], references: [id], onDelete: Cascade)
  employee      Employee      @relation(fields: [employeeId], references: [id], onDelete: Restrict)

  items PayrollRecordItem[]

  @@unique([payrollPeriodId, employeeId])
  @@index([employeeId, status])
  @@index([payrollPeriodId, status])
  @@map("payroll_records")
}

model PayrollRecordItem {
  id                String                 @id @default(cuid()) @db.VarChar(30)
  payrollRecordId   String                 @map("payroll_record_id") @db.VarChar(30)
  salaryComponentId String?                @map("salary_component_id") @db.VarChar(30)
  itemName          String                 @map("item_name") @db.VarChar(191)
  itemType          SalaryComponentType    @map("item_type")
  amount            Decimal                @db.Decimal(18, 2)
  sourceType        PayrollItemSourceType? @map("source_type")
  notes             String?                @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  payrollRecord   PayrollRecord    @relation(fields: [payrollRecordId], references: [id], onDelete: Cascade)
  salaryComponent SalaryComponent? @relation(fields: [salaryComponentId], references: [id], onDelete: SetNull)

  @@index([payrollRecordId])
  @@index([salaryComponentId])
  @@map("payroll_record_items")
}

model PayrollAdjustment {
  id              String                  @id @default(cuid()) @db.VarChar(30)
  employeeId      String                  @map("employee_id") @db.VarChar(30)
  payrollPeriodId String?                 @map("payroll_period_id") @db.VarChar(30)
  adjustmentType  PayrollAdjustmentType   @map("adjustment_type")
  amount          Decimal                 @db.Decimal(18, 2)
  reason          String?                 @db.Text
  status          PayrollAdjustmentStatus @default(PENDING)

  createdByUserId  String? @map("created_by_user_id") @db.VarChar(30)
  approvedByUserId String? @map("approved_by_user_id") @db.VarChar(30)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  employee      Employee       @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  payrollPeriod PayrollPeriod? @relation(fields: [payrollPeriodId], references: [id], onDelete: SetNull)

  createdByUser  User? @relation("PayrollAdjustmentCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  approvedByUser User? @relation("PayrollAdjustmentApprovedBy", fields: [approvedByUserId], references: [id], onDelete: SetNull)

  @@index([employeeId, status])
  @@index([payrollPeriodId])
  @@index([createdByUserId])
  @@index([approvedByUserId])
  @@map("payroll_adjustments")
}

model User {
  id                 String        @id @default(cuid()) @db.VarChar(30)
  employeeId         String?       @unique @map("employee_id") @db.VarChar(30)
  email              String        @unique @db.VarChar(191)
  passwordHash       String?       @map("password_hash") @db.VarChar(255)
  fullName           String?       @map("full_name") @db.VarChar(191)
  avatarUrl          String?       @map("avatar_url") @db.VarChar(2048)
  accountStatus      AccountStatus @default(PENDING) @map("account_status")
  mustChangePassword Boolean       @default(false) @map("must_change_password")
  lastLoginAt        DateTime?     @map("last_login_at")
  failedLoginCount   Int           @default(0) @map("failed_login_count")
  lockedUntil        DateTime?     @map("locked_until")
  isActive           Boolean       @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  employee Employee? @relation("EmployeeUser", fields: [employeeId], references: [id], onDelete: SetNull)

  userRoles  UserRole[]
  authTokens AuthToken[]
  sessions   UserSession[]

  auditLogs             AuditLog[]     @relation("AuditActor")
  receivedNotifications Notification[] @relation("NotificationRecipient")
  sentNotifications     Notification[] @relation("NotificationSender")

  employeesCreated Employee[] @relation("EmployeeCreatedBy")
  employeesUpdated Employee[] @relation("EmployeeUpdatedBy")

  payrollAdjustmentsCreated  PayrollAdjustment[] @relation("PayrollAdjustmentCreatedBy")
  payrollAdjustmentsApproved PayrollAdjustment[] @relation("PayrollAdjustmentApprovedBy")

  @@index([accountStatus, isActive])
  @@index([employeeId])
  @@map("users")
}

model Role {
  id          String  @id @default(cuid()) @db.VarChar(30)
  code        String  @unique @db.VarChar(50)
  name        String  @unique @db.VarChar(100)
  description String? @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  userRoles UserRole[]

  @@map("roles")
}

model UserRole {
  id     String @id @default(cuid()) @db.VarChar(30)
  userId String @map("user_id") @db.VarChar(30)
  roleId String @map("role_id") @db.VarChar(30)

  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([roleId])
  @@map("user_roles")
}

model AuthToken {
  id        String        @id @default(cuid()) @db.VarChar(30)
  userId    String        @map("user_id") @db.VarChar(30)
  tokenType AuthTokenType @map("token_type")
  tokenHash String        @unique @map("token_hash") @db.VarChar(255)
  expiresAt DateTime      @map("expires_at")
  usedAt    DateTime?     @map("used_at")
  createdAt DateTime      @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, tokenType])
  @@index([expiresAt])
  @@map("auth_tokens")
}

model UserSession {
  id               String    @id @default(cuid()) @db.VarChar(30)
  userId           String    @map("user_id") @db.VarChar(30)
  refreshTokenHash String    @unique @map("refresh_token_hash") @db.VarChar(255)
  ipAddress        String?   @map("ip_address") @db.VarChar(64)
  userAgent        String?   @map("user_agent") @db.VarChar(1024)
  expiresAt        DateTime  @map("expires_at")
  revokedAt        DateTime? @map("revoked_at")
  createdAt        DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@map("user_sessions")
}

model Notification {
  id                String           @id @default(cuid()) @db.VarChar(30)
  recipientUserId   String           @map("recipient_user_id") @db.VarChar(30)
  senderUserId      String?          @map("sender_user_id") @db.VarChar(30)
  type              NotificationType
  title             String           @db.VarChar(191)
  message           String           @db.Text
  relatedEntityType String?          @map("related_entity_type") @db.VarChar(50)
  relatedEntityId   String?          @map("related_entity_id") @db.VarChar(30)
  isRead            Boolean          @default(false) @map("is_read")
  readAt            DateTime?        @map("read_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  recipientUser User  @relation("NotificationRecipient", fields: [recipientUserId], references: [id], onDelete: Cascade)
  senderUser    User? @relation("NotificationSender", fields: [senderUserId], references: [id], onDelete: SetNull)

  @@index([recipientUserId, isRead])
  @@index([type])
  @@index([senderUserId])
  @@map("notifications")
}

model AuditLog {
  id          String          @id @default(cuid()) @db.VarChar(30)
  entityType  AuditEntityType @map("entity_type")
  entityId    String          @map("entity_id") @db.VarChar(30)
  actionType  AuditActionType @map("action_type")
  actorUserId String?         @map("actor_user_id") @db.VarChar(30)

  description String? @db.Text
  oldValues   Json?   @map("old_values")
  newValues   Json?   @map("new_values")
  metadata    Json?

  ipAddress String? @map("ip_address") @db.VarChar(64)
  userAgent String? @map("user_agent") @db.VarChar(1024)

  createdAt DateTime @default(now()) @map("created_at")

  actorUser User? @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([createdAt])
  @@index([actorUserId])
  @@map("audit_logs")
}
