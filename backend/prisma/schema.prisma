// ╔══════════════════════════════════════════════════════════╗
// ║              ORGANIZATIONAL MODELS                      ║
// ╚══════════════════════════════════════════════════════════╝

model Department {
  id             String  @id @default(cuid()) @db.VarChar(30)
  name           String  @unique @db.VarChar(191)
  description    String? @db.Text
  headEmployeeId String? @map("head_employee_id") @db.VarChar(30)
  isActive       Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  headEmployee Employee?  @relation("DepartmentHead", fields: [headEmployeeId], references: [id], onDelete: SetNull)
  employees    Employee[] @relation("EmployeeDepartment")

  @@index([headEmployeeId])
  @@index([isActive])
  @@map("departments")
}

model JobTitle {
  id          String  @id @default(cuid()) @db.VarChar(30)
  code        String? @unique @db.VarChar(50)
  name        String  @unique @db.VarChar(191)
  description String? @db.Text
  isActive    Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  employees Employee[] @relation("EmployeeJobTitle")

  @@index([isActive])
  @@map("job_titles")
}

// ╔══════════════════════════════════════════════════════════╗
// ║                   EMPLOYEE MODELS                       ║
// ╚══════════════════════════════════════════════════════════╝

model Employee {
  id           String  @id @default(cuid()) @db.VarChar(30)
  employeeCode String? @unique @map("employee_code") @db.VarChar(50)
  fullName     String  @map("full_name") @db.VarChar(191)
  workEmail    String  @unique @map("work_email") @db.VarChar(191)
  phoneNumber  String? @map("phone_number") @db.VarChar(30)

  departmentId String? @map("department_id") @db.VarChar(30)
  jobTitleId   String? @map("job_title_id") @db.VarChar(30)
  managerId    String? @map("manager_id") @db.VarChar(30)

  hireDate           DateTime         @map("hire_date") @db.Date
  employmentStatus   EmploymentStatus @default(ACTIVE) @map("employment_status")
  isActive           Boolean          @default(true) @map("is_active")
  deactivatedAt      DateTime?        @map("deactivated_at")
  deactivationReason String?          @map("deactivation_reason") @db.Text

  avatarUrl String? @map("avatar_url") @db.VarChar(2048)
  notes     String? @db.Text

  createdByUserId String? @map("created_by_user_id") @db.VarChar(30)
  updatedByUserId String? @map("updated_by_user_id") @db.VarChar(30)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  department Department? @relation("EmployeeDepartment", fields: [departmentId], references: [id], onDelete: SetNull)
  jobTitle   JobTitle?   @relation("EmployeeJobTitle", fields: [jobTitleId], references: [id], onDelete: SetNull)
  manager    Employee?   @relation("EmployeeManager", fields: [managerId], references: [id], onDelete: SetNull)

  subordinates        Employee[]                  @relation("EmployeeManager")
  headedDepartments   Department[]                @relation("DepartmentHead")
  profile             EmployeeProfile?
  leaveRequests       LeaveRequest[]              @relation("LeaveRequester")
  leaveApprovals      LeaveRequestApproval[]      @relation("LeaveApprover")
  leaveBalances       LeaveBalance[]              // [NEW]
  attendanceRecords   AttendanceRecord[]
  overtimeRequests    OvertimeRequest[]           @relation("OvertimeRequester") // [NEW]
  overtimeApprovals   OvertimeRequest[]           @relation("OvertimeApprover")  // [NEW]
  projectAssignments  EmployeeProjectAssignment[]
  managedProjects     Project[]                   @relation("ProjectManager")
  milestoneOwnerships ProjectMilestone[]          @relation("MilestoneOwner")
  projectExpenses     ProjectExpense[]            @relation("ExpenseSubmitter")  // [NEW]
  compensations       EmployeeCompensation[]
  salaryComponents    EmployeeSalaryComponent[]
  payrollRecords      PayrollRecord[]
  payrollAdjustments  PayrollAdjustment[]
  managedClients      Client[]                    @relation("ClientAccountManager") // [NEW]
  user                User?                       @relation("EmployeeUser")
  createdByUser       User?                       @relation("EmployeeCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUser       User?                       @relation("EmployeeUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@index([fullName])
  @@index([departmentId])
  @@index([jobTitleId])
  @@index([managerId])
  @@index([employmentStatus, isActive])
  @@index([createdByUserId])
  @@index([updatedByUserId])
  @@map("employees")
}

model EmployeeProfile {
  id         String @id @default(cuid()) @db.VarChar(30)
  employeeId String @unique @map("employee_id") @db.VarChar(30)

  dateOfBirth DateTime? @map("date_of_birth") @db.Date
  gender      Gender?

  addressLine1 String? @map("address_line_1") @db.VarChar(255)
  addressLine2 String? @map("address_line_2") @db.VarChar(255)
  ward         String? @db.VarChar(100)
  district     String? @db.VarChar(100)
  city         String? @db.VarChar(100)
  province     String? @db.VarChar(100)
  country      String? @db.VarChar(100)
  postalCode   String? @map("postal_code") @db.VarChar(20)

  emergencyContactName         String? @map("emergency_contact_name") @db.VarChar(191)
  emergencyContactRelationship String? @map("emergency_contact_relationship") @db.VarChar(100)
  emergencyContactPhone        String? @map("emergency_contact_phone") @db.VarChar(30)
  emergencyContactEmail        String? @map("emergency_contact_email") @db.VarChar(191)

  // Thông tin ngân hàng
  bankName          String? @map("bank_name") @db.VarChar(191)
  bankAccountNumber String? @map("bank_account_number") @db.VarChar(100)
  bankAccountHolder String? @map("bank_account_holder") @db.VarChar(191)
  bankBranch        String? @map("bank_branch") @db.VarChar(191)
  bankSwiftCode     String? @map("bank_swift_code") @db.VarChar(20) // [NEW]

  // Giấy tờ cá nhân
  taxCode          String? @map("tax_code") @db.VarChar(100)
  nationalIdNumber String? @map("national_id_number") @db.VarChar(50)  // [NEW] CCCD/CMND
  nationalIdIssued DateTime? @map("national_id_issued") @db.Date       // [NEW] Ngày cấp
  nationalIdPlace  String? @map("national_id_place") @db.VarChar(191)  // [NEW] Nơi cấp
  passportNumber   String? @map("passport_number") @db.VarChar(50)     // [NEW]
  passportExpiry   DateTime? @map("passport_expiry") @db.Date          // [NEW]

  // Thông tin bảo hiểm xã hội
  socialInsuranceNumber String? @map("social_insurance_number") @db.VarChar(50)  // [NEW] Mã số BHXH
  healthInsuranceNumber String? @map("health_insurance_number") @db.VarChar(50)  // [NEW] Mã thẻ BHYT
  healthInsuranceExpiry DateTime? @map("health_insurance_expiry") @db.Date       // [NEW] Hạn thẻ BHYT

  // Người phụ thuộc (ảnh hưởng thuế TNCN)
  dependantCount Int @default(0) @map("dependant_count") // [NEW] Số người phụ thuộc

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("employee_profiles")
}

// ╔══════════════════════════════════════════════════════════╗
// ║                 LEAVE MANAGEMENT                        ║
// ╚══════════════════════════════════════════════════════════╝

model LeaveType {
  id          String  @id @default(cuid()) @db.VarChar(30)
  code        String? @unique @db.VarChar(50)
  name        String  @unique @db.VarChar(191)
  description String? @db.Text
  isPaid      Boolean @default(true) @map("is_paid")
  isActive    Boolean @default(true) @map("is_active")

  // [NEW] Chính sách nghỉ phép
  maxDaysPerYear    Int?     @map("max_days_per_year")   // Tối đa bao nhiêu ngày/năm
  maxDaysPerRequest Int?     @map("max_days_per_request") // Tối đa mỗi đơn
  minDaysNotice     Int?     @map("min_days_notice")     // Phải báo trước bao nhiêu ngày
  carryOverDays     Int      @default(0) @map("carry_over_days") // Ngày được chuyển sang năm sau
  requiresDocument  Boolean  @default(false) @map("requires_document") // Cần nộp giấy tờ (ví dụ: giấy bệnh viện)
  requiresApproval  Boolean  @default(true) @map("requires_approval")
  isHalfDayAllowed  Boolean  @default(true) @map("is_half_day_allowed") // Cho phép nghỉ nửa ngày

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  leaveRequests LeaveRequest[]
  leaveBalances LeaveBalance[] // [NEW]

  @@index([isActive])
  @@map("leave_types")
}

// [NEW] Số dư ngày phép của từng nhân viên theo năm & loại
model LeaveBalance {
  id          String @id @default(cuid()) @db.VarChar(30)
  employeeId  String @map("employee_id") @db.VarChar(30)
  leaveTypeId String @map("leave_type_id") @db.VarChar(30)
  year        Int    @db.UnsignedSmallInt

  // Ngày phép được cấp đầu năm / theo chính sách
  entitledDays  Decimal @map("entitled_days") @db.Decimal(5, 2)
  // Ngày phép chuyển từ năm trước
  carriedDays   Decimal @default(0) @map("carried_days") @db.Decimal(5, 2)
  // Ngày phép được cộng thêm (thưởng phép, phát sinh)
  adjustedDays  Decimal @default(0) @map("adjusted_days") @db.Decimal(5, 2)
  // Ngày đã sử dụng (tính từ đơn được duyệt)
  usedDays      Decimal @default(0) @map("used_days") @db.Decimal(5, 2)
  // Ngày đang chờ duyệt
  pendingDays   Decimal @default(0) @map("pending_days") @db.Decimal(5, 2)
  // Số dư còn lại = entitledDays + carriedDays + adjustedDays - usedDays - pendingDays
  remainingDays Decimal @default(0) @map("remaining_days") @db.Decimal(5, 2)

  notes     String? @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  employee  Employee  @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id], onDelete: Restrict)

  @@unique([employeeId, leaveTypeId, year])
  @@index([employeeId, year])
  @@index([leaveTypeId])
  @@map("leave_balances")
}

model LeaveRequest {
  id          String @id @default(cuid()) @db.VarChar(30)
  employeeId  String @map("employee_id") @db.VarChar(30)
  leaveTypeId String @map("leave_type_id") @db.VarChar(30)

  startDate  DateTime @map("start_date") @db.Date
  endDate    DateTime @map("end_date") @db.Date
  totalDays  Decimal  @map("total_days") @db.Decimal(5, 2)
  isHalfDay  Boolean  @default(false) @map("is_half_day")    // [NEW]
  halfDayPeriod String? @map("half_day_period") @db.VarChar(10) // [NEW] "MORNING" | "AFTERNOON"
  reason     String?  @db.Text
  documentUrl String? @map("document_url") @db.VarChar(2048) // [NEW] Đính kèm giấy tờ

  status      LeaveRequestStatus @default(PENDING)
  currentStep ApprovalStepType?  @map("current_step")

  submittedAt     DateTime  @default(now()) @map("submitted_at")
  finalApprovedAt DateTime? @map("final_approved_at")
  rejectedAt      DateTime? @map("rejected_at")
  rejectionReason String?   @map("rejection_reason") @db.Text
  cancelledAt     DateTime? @map("cancelled_at")               // [NEW]
  cancelReason    String?   @map("cancel_reason") @db.Text     // [NEW]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  employee  Employee  @relation("LeaveRequester", fields: [employeeId], references: [id], onDelete: Restrict)
  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id], onDelete: Restrict)
  approvals LeaveRequestApproval[]

  @@index([employeeId, status])
  @@index([leaveTypeId])
  @@index([startDate, endDate])
  @@map("leave_requests")
}

model LeaveRequestApproval {
  id                 String @id @default(cuid()) @db.VarChar(30)
  leaveRequestId     String @map("leave_request_id") @db.VarChar(30)
  approverEmployeeId String @map("approver_employee_id") @db.VarChar(30)

  stepType  ApprovalStepType @map("step_type")
  stepOrder Int              @map("step_order")
  status    ApprovalStatus   @default(PENDING)

  comment  String?   @db.Text
  actionAt DateTime? @map("action_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  leaveRequest LeaveRequest @relation(fields: [leaveRequestId], references: [id], onDelete: Cascade)
  approver     Employee     @relation("LeaveApprover", fields: [approverEmployeeId], references: [id], onDelete: Restrict)

  @@unique([leaveRequestId, stepType])
  @@unique([leaveRequestId, stepOrder])
  @@index([approverEmployeeId, status])
  @@map("leave_request_approvals")
}

// ╔══════════════════════════════════════════════════════════╗
// ║              ATTENDANCE & OVERTIME                      ║
// ╚══════════════════════════════════════════════════════════╝

// [NEW] Lịch ngày nghỉ lễ / ngày đặc biệt
model Holiday {
  id          String  @id @default(cuid()) @db.VarChar(30)
  name        String  @db.VarChar(191)
  date        DateTime @db.Date
  year        Int      @db.UnsignedSmallInt
  isRecurring Boolean  @default(false) @map("is_recurring") // Lặp lại hàng năm
  description String?  @db.Text
  overtimeMultiplier Decimal @default(3.0) @map("overtime_multiplier") @db.Decimal(3, 1) // Hệ số lương ngày lễ

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([date])
  @@index([year])
  @@map("holidays")
}

// [NEW] Ca làm việc
model WorkShift {
  id          String    @id @default(cuid()) @db.VarChar(30)
  code        String    @unique @db.VarChar(50)
  name        String    @unique @db.VarChar(191)
  shiftType   ShiftType @map("shift_type")
  startTime   String    @map("start_time") @db.VarChar(5)   // "08:00" định dạng HH:mm
  endTime     String    @map("end_time") @db.VarChar(5)     // "17:30"
  breakMinutes Int      @default(60) @map("break_minutes")   // Phút nghỉ giữa ca
  workMinutes  Int      @map("work_minutes")                  // Tổng phút làm việc tiêu chuẩn
  isNightShift Boolean  @default(false) @map("is_night_shift")
  overtimeAfterMinutes Int @default(0) @map("overtime_after_minutes") // OT tính sau bao nhiêu phút làm thêm
  isActive     Boolean  @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  attendanceRecords AttendanceRecord[]

  @@index([isActive])
  @@map("work_shifts")
}

model AttendanceRecord {
  id         String @id @default(cuid()) @db.VarChar(30)
  employeeId String @map("employee_id") @db.VarChar(30)
  shiftId    String? @map("shift_id") @db.VarChar(30) // [NEW]

  workDate         DateTime         @map("work_date") @db.Date
  checkInAt        DateTime?        @map("check_in_at")
  checkOutAt       DateTime?        @map("check_out_at")
  totalWorkMinutes Int?             @map("total_work_minutes")

  // [NEW] Chi tiết chấm công
  lateMinutes          Int @default(0) @map("late_minutes")           // Số phút đi muộn
  earlyLeaveMinutes    Int @default(0) @map("early_leave_minutes")     // Số phút về sớm
  overtimeMinutes      Int @default(0) @map("overtime_minutes")        // Số phút OT thực tế
  overtimeApprovedMinutes Int @default(0) @map("overtime_approved_minutes") // Phút OT được duyệt
  isHolidayWork        Boolean @default(false) @map("is_holiday_work") // Làm việc ngày lễ
  isWeekendWork        Boolean @default(false) @map("is_weekend_work") // Làm việc cuối tuần
  isRemoteWork         Boolean @default(false) @map("is_remote_work")  // Làm việc từ xa

  status AttendanceStatus @default(CHECKED_IN)
  note   String?          @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  employee  Employee   @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  shift     WorkShift? @relation(fields: [shiftId], references: [id], onDelete: SetNull) // [NEW]

  @@unique([employeeId, workDate])
  @@index([workDate])
  @@index([employeeId, status])
  @@index([shiftId])
  @@map("attendance_records")
}

// [NEW] Yêu cầu làm thêm giờ (cần approval trước khi tính vào lương)
model OvertimeRequest {
  id                 String @id @default(cuid()) @db.VarChar(30)
  employeeId         String @map("employee_id") @db.VarChar(30)
  approverEmployeeId String? @map("approver_employee_id") @db.VarChar(30)

  workDate     DateTime @map("work_date") @db.Date
  startTime    String   @map("start_time") @db.VarChar(5)  // "18:00"
  endTime      String   @map("end_time") @db.VarChar(5)    // "21:00"
  plannedMinutes Int    @map("planned_minutes")
  actualMinutes  Int?   @map("actual_minutes")             // Thực tế sau khi chấm công

  isHoliday    Boolean @default(false) @map("is_holiday")
  isWeekend    Boolean @default(false) @map("is_weekend")
  reason       String? @db.Text
  status       OvertimeRequestStatus @default(PENDING)

  submittedAt DateTime  @default(now()) @map("submitted_at")
  actionAt    DateTime? @map("action_at")
  comment     String?   @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  employee Employee  @relation("OvertimeRequester", fields: [employeeId], references: [id], onDelete: Restrict)
  approver Employee? @relation("OvertimeApprover", fields: [approverEmployeeId], references: [id], onDelete: SetNull)

  @@index([employeeId, status])
  @@index([workDate])
  @@index([approverEmployeeId])
  @@map("overtime_requests")
}

// ╔══════════════════════════════════════════════════════════╗
// ║                  PROJECT MODELS                         ║
// ╚══════════════════════════════════════════════════════════╝

model Project {
  id          String  @id @default(cuid()) @db.VarChar(30)
  projectCode String? @unique @map("project_code") @db.VarChar(50)
  projectName String  @map("project_name") @db.VarChar(191)
  description String? @db.Text

  projectManagerEmployeeId String?              @map("project_manager_employee_id") @db.VarChar(30)

  // [CHANGED] clientName String → FK sang bảng Client
  clientId    String? @map("client_id") @db.VarChar(30)   // [NEW]
  contractId  String? @map("contract_id") @db.VarChar(30) // [NEW] Hợp đồng gắn với dự án

  status          ProjectStatus        @default(PLANNING)
  priority        ProjectPriority?
  healthStatus    ProjectHealthStatus? @map("health_status")
  progressPercent Decimal              @default(0) @map("progress_percent") @db.Decimal(5, 2)

  startDate     DateTime? @map("start_date") @db.Date
  endDate       DateTime? @map("end_date") @db.Date
  actualEndDate DateTime? @map("actual_end_date") @db.Date

  // [IMPROVED] Ngân sách dự án chi tiết hơn
  budgetAmount   Decimal? @map("budget_amount") @db.Decimal(18, 2)   // Tổng ngân sách được duyệt
  spentAmount    Decimal  @default(0) @map("spent_amount") @db.Decimal(18, 2)  // [NEW] Đã chi
  currency       String   @default("VND") @db.VarChar(10)            // [NEW]

  // [NEW] Doanh thu từ dự án (billable)
  contractValue  Decimal? @map("contract_value") @db.Decimal(18, 2)  // Giá trị hợp đồng
  invoicedAmount Decimal  @default(0) @map("invoiced_amount") @db.Decimal(18, 2) // Đã xuất hóa đơn
  receivedAmount Decimal  @default(0) @map("received_amount") @db.Decimal(18, 2) // Đã thu được

  isActive Boolean @default(true) @map("is_active")
  closedAt DateTime? @map("closed_at")     // [NEW]
  closureNote String? @map("closure_note") @db.Text // [NEW]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  projectManager Employee? @relation("ProjectManager", fields: [projectManagerEmployeeId], references: [id], onDelete: SetNull)
  client         Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull) // [NEW]
  contract       Contract? @relation("ProjectContract", fields: [contractId], references: [id], onDelete: SetNull) // [NEW]

  assignments EmployeeProjectAssignment[]  @relation("ProjectAssignments")
  milestones  ProjectMilestone[]
  expenses    ProjectExpense[]      // [NEW]
  invoices    Invoice[]             // [NEW] Hóa đơn xuất cho dự án này

  @@index([projectManagerEmployeeId])
  @@index([clientId])
  @@index([contractId])
  @@index([status, isActive])
  @@index([healthStatus])
  @@index([priority])
  @@index([startDate, endDate])
  @@map("projects")
}

model EmployeeProjectAssignment {
  id         String @id @default(cuid()) @db.VarChar(30)
  employeeId String @map("employee_id") @db.VarChar(30)
  projectId  String @map("project_id") @db.VarChar(30)

  roleInProject     String?                 @map("role_in_project") @db.VarChar(100)
  allocationPercent Decimal?                @map("allocation_percent") @db.Decimal(5, 2)
  hourlyRate        Decimal?                @map("hourly_rate") @db.Decimal(18, 2) // [NEW] Giá theo giờ (nếu billable)
  joinedAt          DateTime                @map("joined_at") @db.Date
  leftAt            DateTime?               @map("left_at") @db.Date
  status            ProjectAssignmentStatus @default(ACTIVE)
  isBillable        Boolean                 @default(false) @map("is_billable")
  notes             String?                 @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  project  Project  @relation("ProjectAssignments", fields: [projectId], references: [id], onDelete: Restrict)

  @@unique([employeeId, projectId, joinedAt])
  @@index([employeeId, status])
  @@index([projectId, status])
  @@map("employee_project_assignments")
}

model ProjectMilestone {
  id              String          @id @default(cuid()) @db.VarChar(30)
  projectId       String          @map("project_id") @db.VarChar(30)
  name            String          @db.VarChar(191)
  description     String?         @db.Text
  ownerEmployeeId String?         @map("owner_employee_id") @db.VarChar(30)
  dueDate         DateTime?       @map("due_date") @db.Date
  completedAt     DateTime?       @map("completed_at")
  status          MilestoneStatus @default(PENDING)

  // [NEW] Liên kết milestone với hóa đơn (milestone = điều kiện thanh toán)
  invoiceId String? @map("invoice_id") @db.VarChar(30)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  project Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  owner   Employee? @relation("MilestoneOwner", fields: [ownerEmployeeId], references: [id], onDelete: SetNull)
  invoice Invoice?  @relation(fields: [invoiceId], references: [id], onDelete: SetNull) // [NEW]

  @@index([projectId, status])
  @@index([ownerEmployeeId])
  @@index([dueDate])
  @@map("project_milestones")
}

// [NEW] Chi phí phát sinh trong dự án
model ProjectExpense {
  id                  String               @id @default(cuid()) @db.VarChar(30)
  projectId           String               @map("project_id") @db.VarChar(30)
  submittedByEmployeeId String             @map("submitted_by_employee_id") @db.VarChar(30)
  approvedByUserId    String?              @map("approved_by_user_id") @db.VarChar(30)

  category     ProjectExpenseCategory @map("category")
  title        String                 @db.VarChar(191)
  description  String?                @db.Text
  amount       Decimal                @db.Decimal(18, 2)
  currency     String                 @default("VND") @db.VarChar(10)
  expenseDate  DateTime               @map("expense_date") @db.Date
  receiptUrl   String?                @map("receipt_url") @db.VarChar(2048) // Ảnh hóa đơn
  status       ProjectExpenseStatus   @default(PENDING)

  submittedAt DateTime  @default(now()) @map("submitted_at")
  approvedAt  DateTime? @map("approved_at")
  rejectedAt  DateTime? @map("rejected_at")
  rejectReason String?  @map("reject_reason") @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  project       Project   @relation(fields: [projectId], references: [id], onDelete: Restrict)
  submittedBy   Employee  @relation("ExpenseSubmitter", fields: [submittedByEmployeeId], references: [id], onDelete: Restrict)
  approvedByUser User?    @relation("ExpenseApprover", fields: [approvedByUserId], references: [id], onDelete: SetNull)

  @@index([projectId, status])
  @@index([submittedByEmployeeId])
  @@index([expenseDate])
  @@map("project_expenses")
}

// ╔══════════════════════════════════════════════════════════╗
// ║              PAYROLL & COMPENSATION                     ║
