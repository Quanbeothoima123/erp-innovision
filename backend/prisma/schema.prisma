// [NEW] Chính sách bảo hiểm (theo quy định nhà nước, cập nhật theo từng thời kỳ)
model InsurancePolicy {
  id          String              @id @default(cuid()) @db.VarChar(30)
  policyType  InsurancePolicyType @map("policy_type")
  name        String              @db.VarChar(191)

  // Tỷ lệ đóng
  employeeRate  Decimal @map("employee_rate") @db.Decimal(5, 4)  // VD: 0.08 = 8%
  employerRate  Decimal @map("employer_rate") @db.Decimal(5, 4)  // VD: 0.175 = 17.5%

  // Mức lương trần đóng bảo hiểm (nếu có)
  salaryCapAmount Decimal? @map("salary_cap_amount") @db.Decimal(18, 2)

  effectiveFrom DateTime  @map("effective_from") @db.Date
  effectiveTo   DateTime? @map("effective_to") @db.Date
  isActive      Boolean   @default(true) @map("is_active")
  notes         String?   @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([policyType, isActive])
  @@index([effectiveFrom])
  @@map("insurance_policies")
}

// [NEW] Bảng thuế TNCN lũy tiến (progressive tax brackets)
model TaxPolicy {
  id          String @id @default(cuid()) @db.VarChar(30)
  name        String @db.VarChar(191)  // VD: "Thuế TNCN 2024"
  year        Int    @db.UnsignedSmallInt
  description String? @db.Text
  isActive    Boolean @default(true) @map("is_active")

  // Mức giảm trừ gia cảnh
  personalDeduction  Decimal @map("personal_deduction") @db.Decimal(18, 2)  // Bản thân (hiện 11tr/tháng)
  dependantDeduction Decimal @map("dependant_deduction") @db.Decimal(18, 2) // Mỗi người phụ thuộc (4.4tr/tháng)

  effectiveFrom DateTime  @map("effective_from") @db.Date
  effectiveTo   DateTime? @map("effective_to") @db.Date

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  brackets TaxBracket[]

  @@index([year, isActive])
  @@map("tax_policies")
}

// [NEW] Các bậc thuế (7 bậc thuế TNCN VN)
model TaxBracket {
  id           String @id @default(cuid()) @db.VarChar(30)
  taxPolicyId  String @map("tax_policy_id") @db.VarChar(30)
  bracketOrder Int    @map("bracket_order")           // Bậc 1, 2, 3...
  minIncome    Decimal @map("min_income") @db.Decimal(18, 2) // Thu nhập tính thuế từ
  maxIncome    Decimal? @map("max_income") @db.Decimal(18, 2) // Đến (null = không giới hạn)
  taxRate      Decimal  @map("tax_rate") @db.Decimal(5, 4)   // VD: 0.05 = 5%

  taxPolicy TaxPolicy @relation(fields: [taxPolicyId], references: [id], onDelete: Cascade)

  @@unique([taxPolicyId, bracketOrder])
  @@index([taxPolicyId])
  @@map("tax_brackets")
}

model PayrollPeriod {
  id         String              @id @default(cuid()) @db.VarChar(30)
  periodCode String              @unique @map("period_code") @db.VarChar(50)
  month      Int                 @db.UnsignedTinyInt
  year       Int                 @db.UnsignedSmallInt
  startDate  DateTime            @map("start_date") @db.Date
  endDate    DateTime            @map("end_date") @db.Date
  payDate    DateTime?           @map("pay_date") @db.Date
  status     PayrollPeriodStatus @default(DRAFT)

  // [NEW] Tham số kỳ lương
  workingDaysInPeriod     Int? @map("working_days_in_period")      // Tổng ngày làm việc trong kỳ
  standardWorkingMinutes  Int? @map("standard_working_minutes")    // Phút làm chuẩn 1 ngày

  lockedAt   DateTime? @map("locked_at")
  approvedAt DateTime? @map("approved_at")
  paidAt     DateTime? @map("paid_at")

  // [NEW] Người phê duyệt
  approvedByUserId String? @map("approved_by_user_id") @db.VarChar(30)
  notes            String? @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  payrollRecords     PayrollRecord[]
  payrollAdjustments PayrollAdjustment[]
  approvedByUser     User?               @relation("PayrollPeriodApprover", fields: [approvedByUserId], references: [id], onDelete: SetNull)

  @@unique([month, year])
  @@index([status])
  @@map("payroll_periods")
}

model EmployeeCompensation {
  id                   String     @id @default(cuid()) @db.VarChar(30)
  employeeId           String     @map("employee_id") @db.VarChar(30)
  salaryType           SalaryType @map("salary_type")
  baseSalary           Decimal    @map("base_salary") @db.Decimal(18, 2)

  // [NEW] Lương thử việc (thường 85% lương chính thức)
  probationSalary      Decimal?   @map("probation_salary") @db.Decimal(18, 2)

  standardWorkingDays  Int?       @map("standard_working_days")
  standardWorkingHours Decimal?   @map("standard_working_hours") @db.Decimal(5, 2)
  currency             String     @db.VarChar(10)

  // [NEW] Hệ số làm thêm giờ
  overtimeRateWeekday  Decimal @default(1.5) @map("overtime_rate_weekday") @db.Decimal(3, 1) // 150% ngày thường
  overtimeRateWeekend  Decimal @default(2.0) @map("overtime_rate_weekend") @db.Decimal(3, 1) // 200% cuối tuần
  overtimeRateHoliday  Decimal @default(3.0) @map("overtime_rate_holiday") @db.Decimal(3, 1) // 300% ngày lễ

  effectiveFrom DateTime  @map("effective_from") @db.Date
  effectiveTo   DateTime? @map("effective_to") @db.Date
  isActive      Boolean   @default(true) @map("is_active")
  notes         String?   @db.Text // [NEW]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Restrict)

  @@unique([employeeId, effectiveFrom])
  @@index([employeeId, isActive])
  @@map("employee_compensations")
}

model SalaryComponent {
  id              String                @id @default(cuid()) @db.VarChar(30)
  code            String                @unique @db.VarChar(50)
  name            String                @unique @db.VarChar(191)
  componentType   SalaryComponentType   @map("component_type")
  calculationType SalaryCalculationType @map("calculation_type")
  isTaxable       Boolean               @default(false) @map("is_taxable")
  isInsurable     Boolean               @default(false) @map("is_insurable")
  isActive        Boolean               @default(true) @map("is_active")

  // [NEW] Thứ tự ưu tiên tính lương
  displayOrder    Int @default(0) @map("display_order")
  description     String? @db.Text // [NEW]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  employeeSalaryComponents EmployeeSalaryComponent[]
  payrollRecordItems       PayrollRecordItem[]

  @@index([componentType, isActive])
  @@map("salary_components")
}

model EmployeeSalaryComponent {
  id                String    @id @default(cuid()) @db.VarChar(30)
  employeeId        String    @map("employee_id") @db.VarChar(30)
  salaryComponentId String    @map("salary_component_id") @db.VarChar(30)
  amount            Decimal   @db.Decimal(18, 2)
  effectiveFrom     DateTime  @map("effective_from") @db.Date
  effectiveTo       DateTime? @map("effective_to") @db.Date
  isActive          Boolean   @default(true) @map("is_active")
  notes             String?   @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  employee        Employee        @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  salaryComponent SalaryComponent @relation(fields: [salaryComponentId], references: [id], onDelete: Restrict)

  @@unique([employeeId, salaryComponentId, effectiveFrom])
  @@index([employeeId, isActive])
  @@index([salaryComponentId])
  @@map("employee_salary_components")
}

model PayrollRecord {
  id              String @id @default(cuid()) @db.VarChar(30)
  payrollPeriodId String @map("payroll_period_id") @db.VarChar(30)
  employeeId      String @map("employee_id") @db.VarChar(30)

  baseSalary      Decimal             @map("base_salary") @db.Decimal(18, 2)
  workingDays     Decimal?            @map("working_days") @db.Decimal(5, 2)
  paidLeaveDays   Decimal?            @map("paid_leave_days") @db.Decimal(5, 2)
  unpaidLeaveDays Decimal?            @map("unpaid_leave_days") @db.Decimal(5, 2)
  absentDays      Decimal?            @map("absent_days") @db.Decimal(5, 2)     // [NEW]
  lateDays        Int     @default(0) @map("late_days")                         // [NEW] Số ngày đi muộn bị trừ

  // [NEW] Làm thêm giờ
  overtimeWeekdayMinutes Int @default(0) @map("overtime_weekday_minutes")
  overtimeWeekendMinutes Int @default(0) @map("overtime_weekend_minutes")
  overtimeHolidayMinutes Int @default(0) @map("overtime_holiday_minutes")
  totalOvertimePay    Decimal @default(0) @map("total_overtime_pay") @db.Decimal(18, 2)

  grossSalary     Decimal             @map("gross_salary") @db.Decimal(18, 2)
  totalAllowances Decimal             @map("total_allowances") @db.Decimal(18, 2)
  totalBonus      Decimal             @map("total_bonus") @db.Decimal(18, 2)

  // [NEW] Chi tiết khấu trừ
  socialInsuranceEmployee  Decimal @default(0) @map("social_insurance_employee") @db.Decimal(18, 2)
  healthInsuranceEmployee  Decimal @default(0) @map("health_insurance_employee") @db.Decimal(18, 2)
  unemploymentInsuranceEmployee Decimal @default(0) @map("unemployment_insurance_employee") @db.Decimal(18, 2)
  personalIncomeTax        Decimal @default(0) @map("personal_income_tax") @db.Decimal(18, 2)
  taxableIncome            Decimal @default(0) @map("taxable_income") @db.Decimal(18, 2) // Thu nhập tính thuế

  totalDeductions Decimal             @map("total_deductions") @db.Decimal(18, 2)
  netSalary       Decimal             @map("net_salary") @db.Decimal(18, 2)
  status          PayrollRecordStatus @default(DRAFT)

  // [NEW] Tham số tính lương
  dailyRate    Decimal? @map("daily_rate") @db.Decimal(18, 2)  // Lương 1 ngày
  hourlyRate   Decimal? @map("hourly_rate") @db.Decimal(18, 2) // Lương 1 giờ

  generatedAt  DateTime? @map("generated_at")
  approvedAt   DateTime? @map("approved_at")
  paidAt       DateTime? @map("paid_at")
  paymentRef   String?   @map("payment_ref") @db.VarChar(191) // [NEW] Mã giao dịch chuyển lương

  notes String? @db.Text // [NEW]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  payrollPeriod PayrollPeriod @relation(fields: [payrollPeriodId], references: [id], onDelete: Cascade)
  employee      Employee      @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  items         PayrollRecordItem[]

  @@unique([payrollPeriodId, employeeId])
  @@index([employeeId, status])
  @@index([payrollPeriodId, status])
  @@map("payroll_records")
}

model PayrollRecordItem {
  id                String                 @id @default(cuid()) @db.VarChar(30)
  payrollRecordId   String                 @map("payroll_record_id") @db.VarChar(30)
  salaryComponentId String?                @map("salary_component_id") @db.VarChar(30)
  itemName          String                 @map("item_name") @db.VarChar(191)
  itemType          SalaryComponentType    @map("item_type")
  amount            Decimal                @db.Decimal(18, 2)
  sourceType        PayrollItemSourceType? @map("source_type")
  quantity          Decimal?               @db.Decimal(10, 2) // [NEW] Số giờ OT, số ngày...
  unitRate          Decimal?               @map("unit_rate") @db.Decimal(18, 2) // [NEW] Đơn giá
  notes             String?                @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  payrollRecord   PayrollRecord    @relation(fields: [payrollRecordId], references: [id], onDelete: Cascade)
  salaryComponent SalaryComponent? @relation(fields: [salaryComponentId], references: [id], onDelete: SetNull)

  @@index([payrollRecordId])
  @@index([salaryComponentId])
  @@map("payroll_record_items")
}

model PayrollAdjustment {
  id              String                  @id @default(cuid()) @db.VarChar(30)
  employeeId      String                  @map("employee_id") @db.VarChar(30)
  payrollPeriodId String?                 @map("payroll_period_id") @db.VarChar(30)
  adjustmentType  PayrollAdjustmentType   @map("adjustment_type")
  amount          Decimal                 @db.Decimal(18, 2)
  reason          String?                 @db.Text
  status          PayrollAdjustmentStatus @default(PENDING)

  // [NEW] Nếu là tạm ứng lương, theo dõi việc thu hồi
  isAdvance           Boolean   @default(false) @map("is_advance")
  advanceRecoveredAmount Decimal @default(0) @map("advance_recovered_amount") @db.Decimal(18, 2)
  advanceFullyRecovered Boolean @default(false) @map("advance_fully_recovered")

  createdByUserId  String? @map("created_by_user_id") @db.VarChar(30)
  approvedByUserId String? @map("approved_by_user_id") @db.VarChar(30)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  employee      Employee       @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  payrollPeriod PayrollPeriod? @relation(fields: [payrollPeriodId], references: [id], onDelete: SetNull)
  createdByUser  User? @relation("PayrollAdjustmentCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  approvedByUser User? @relation("PayrollAdjustmentApprovedBy", fields: [approvedByUserId], references: [id], onDelete: SetNull)

  @@index([employeeId, status])
  @@index([payrollPeriodId])
  @@index([createdByUserId])
  @@index([approvedByUserId])
  @@map("payroll_adjustments")
}

// ╔══════════════════════════════════════════════════════════╗
// ║            CLIENT & CONTRACT MANAGEMENT                 ║
// ╚══════════════════════════════════════════════════════════╝

// [NEW] Khách hàng / Nhà đầu tư
model Client {
  id           String       @id @default(cuid()) @db.VarChar(30)
  clientCode   String?      @unique @map("client_code") @db.VarChar(50)   // Mã khách hàng nội bộ
  clientType   ClientType   @map("client_type")
  status       ClientStatus @default(PROSPECT)

  // Thông tin cơ bản
  companyName  String  @map("company_name") @db.VarChar(255)              // Tên công ty / cá nhân
  shortName    String? @map("short_name") @db.VarChar(100)                // Tên viết tắt
  taxCode      String? @map("tax_code") @db.VarChar(50)                   // Mã số thuế doanh nghiệp
  industry     String? @db.VarChar(100)                                   // Ngành nghề
  website      String? @db.VarChar(2048)

  // Địa chỉ
  addressLine1 String? @map("address_line_1") @db.VarChar(255)
  addressLine2 String? @map("address_line_2") @db.VarChar(255)
  city         String? @db.VarChar(100)
  province     String? @db.VarChar(100)
  country      String  @default("Việt Nam") @db.VarChar(100)
  postalCode   String? @map("postal_code") @db.VarChar(20)

  // Tài khoản ngân hàng (để thanh toán / nhận tiền)
  bankName          String? @map("bank_name") @db.VarChar(191)
  bankAccountNumber String? @map("bank_account_number") @db.VarChar(100)
  bankAccountHolder String? @map("bank_account_holder") @db.VarChar(191)
  bankBranch        String? @map("bank_branch") @db.VarChar(191)
  bankSwiftCode     String? @map("bank_swift_code") @db.VarChar(20)

  // Phân công nhân viên phụ trách
  accountManagerId  String? @map("account_manager_id") @db.VarChar(30)

  // Thống kê nhanh (denormalized để tăng tốc query dashboard)
  totalContractValue   Decimal @default(0) @map("total_contract_value") @db.Decimal(18, 2)
  totalInvoicedAmount  Decimal @default(0) @map("total_invoiced_amount") @db.Decimal(18, 2)
  totalReceivedAmount  Decimal @default(0) @map("total_received_amount") @db.Decimal(18, 2)
  outstandingBalance   Decimal @default(0) @map("outstanding_balance") @db.Decimal(18, 2)  // Còn nợ

  notes    String? @db.Text
  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  accountManager Employee? @relation("ClientAccountManager", fields: [accountManagerId], references: [id], onDelete: SetNull)

  contacts   ClientContact[]
  contracts  Contract[]
  invoices   Invoice[]
  payments   ClientPayment[]
  documents  ClientDocument[]
  projects   Project[]

  @@index([status, isActive])
  @@index([clientType])
  @@index([accountManagerId])
  @@index([companyName])
  @@map("clients")
}

// [NEW] Người liên hệ phía khách hàng
model ClientContact {
  id       String @id @default(cuid()) @db.VarChar(30)
  clientId String @map("client_id") @db.VarChar(30)

  fullName    String  @map("full_name") @db.VarChar(191)
  jobTitle    String? @map("job_title") @db.VarChar(191)  // Chức danh bên phía khách hàng
  department  String? @db.VarChar(100)
  email       String? @db.VarChar(191)
  phoneNumber String? @map("phone_number") @db.VarChar(30)
  phoneAlt    String? @map("phone_alt") @db.VarChar(30)  // Số điện thoại phụ

  isPrimary   Boolean @default(false) @map("is_primary")  // Người liên hệ chính
  isBilling   Boolean @default(false) @map("is_billing")  // Nhận hóa đơn
  isTechnical Boolean @default(false) @map("is_technical") // Liên hệ kỹ thuật

  notes    String? @db.Text
  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, isActive])
  @@index([email])
  @@map("client_contacts")
}

// [NEW] Hợp đồng với khách hàng
model Contract {
  id             String @id @default(cuid()) @db.VarChar(30)
  contractCode   String @unique @map("contract_code") @db.VarChar(50)
  title          String @db.VarChar(255)
  clientId       String @map("client_id") @db.VarChar(30)

  contractType   ContractType   @map("contract_type")
  status         ContractStatus @default(DRAFT)

  // Giá trị tài chính
  totalValue       Decimal  @map("total_value") @db.Decimal(18, 2)        // Tổng giá trị hợp đồng
  currency         String   @default("VND") @db.VarChar(10)
  vatRate          Decimal  @default(0.1) @map("vat_rate") @db.Decimal(4, 2) // Thuế GTGT (10%)
  vatAmount        Decimal  @map("vat_amount") @db.Decimal(18, 2)
  totalWithVat     Decimal  @map("total_with_vat") @db.Decimal(18, 2)     // Tổng kể cả thuế

  // Điều khoản thanh toán
  paymentTermDays  Int?     @map("payment_term_days")                      // Net 30, Net 60...
  retainerAmount   Decimal? @map("retainer_amount") @db.Decimal(18, 2)    // Phí duy trì hàng tháng (nếu là retainer)

  // Thời hạn
  signedDate       DateTime? @map("signed_date") @db.Date
  startDate        DateTime? @map("start_date") @db.Date
  endDate          DateTime? @map("end_date") @db.Date
  actualEndDate    DateTime? @map("actual_end_date") @db.Date

  // Tracking tài chính
  invoicedAmount   Decimal @default(0) @map("invoiced_amount") @db.Decimal(18, 2)
  receivedAmount   Decimal @default(0) @map("received_amount") @db.Decimal(18, 2)
  remainingAmount  Decimal @default(0) @map("remaining_amount") @db.Decimal(18, 2) // Còn phải thu

  // Metadata
  description      String? @db.Text
  terms            String? @db.LongText  // Điều khoản hợp đồng
  internalNotes    String? @map("internal_notes") @db.Text
  contractFileUrl  String? @map("contract_file_url") @db.VarChar(2048)   // File scan hợp đồng

  // Người ký / phụ trách nội bộ
  signedByUserId    String? @map("signed_by_user_id") @db.VarChar(30)
  handledByEmployeeId String? @map("handled_by_employee_id") @db.VarChar(30) // Nhân viên phụ trách
  terminatedAt      DateTime? @map("terminated_at")
  terminationReason String?   @map("termination_reason") @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  client              Client              @relation(fields: [clientId], references: [id], onDelete: Restrict)
  signedByUser        User?               @relation("ContractSignedBy", fields: [signedByUserId], references: [id], onDelete: SetNull)

  amendments  ContractAmendment[]
  projects    Project[]           @relation("ProjectContract")
  invoices    Invoice[]
  payments    ClientPayment[]

  @@index([clientId, status])
  @@index([status])
  @@index([startDate, endDate])
  @@index([signedByUserId])
  @@map("contracts")
}

// [NEW] Phụ lục hợp đồng (sửa đổi / bổ sung)
model ContractAmendment {
  id           String @id @default(cuid()) @db.VarChar(30)
  contractId   String @map("contract_id") @db.VarChar(30)
  amendmentCode String @unique @map("amendment_code") @db.VarChar(50) // Số phụ lục
  title        String @db.VarChar(255)

  status       ContractAmendmentStatus @default(DRAFT)

  // Thay đổi so với hợp đồng gốc
  changeDescription String? @map("change_description") @db.Text // Nội dung thay đổi
  valueChange       Decimal? @map("value_change") @db.Decimal(18, 2) // Điều chỉnh giá trị (+/-)
  endDateChange     DateTime? @map("end_date_change") @db.Date       // Điều chỉnh ngày kết thúc

  signedDate      DateTime? @map("signed_date") @db.Date
  effectiveDate   DateTime? @map("effective_date") @db.Date
  fileUrl         String?   @map("file_url") @db.VarChar(2048)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Restrict)

  @@index([contractId, status])
  @@map("contract_amendments")
}

// [NEW] Hóa đơn gửi khách hàng
model Invoice {
  id           String @id @default(cuid()) @db.VarChar(30)
  invoiceCode  String @unique @map("invoice_code") @db.VarChar(50)  // Số hóa đơn
  clientId     String @map("client_id") @db.VarChar(30)
  contractId   String? @map("contract_id") @db.VarChar(30)
  projectId    String? @map("project_id") @db.VarChar(30)

  status       InvoiceStatus @default(DRAFT)

  issuedDate   DateTime  @map("issued_date") @db.Date
  dueDate      DateTime  @map("due_date") @db.Date             // Hạn thanh toán
  paidDate     DateTime? @map("paid_date") @db.Date

  // Số tiền
  subtotal     Decimal  @db.Decimal(18, 2)                     // Trước thuế
  taxRate      Decimal  @default(0.1) @map("tax_rate") @db.Decimal(4, 2)
  taxAmount    Decimal  @map("tax_amount") @db.Decimal(18, 2)
  totalAmount  Decimal  @map("total_amount") @db.Decimal(18, 2)  // Tổng sau thuế
  paidAmount   Decimal  @default(0) @map("paid_amount") @db.Decimal(18, 2) // Đã thanh toán
  outstandingAmount Decimal @default(0) @map("outstanding_amount") @db.Decimal(18, 2) // Còn nợ

  currency     String @default("VND") @db.VarChar(10)

  // Thông tin hóa đơn VAT
  vatInvoiceNumber String? @map("vat_invoice_number") @db.VarChar(50) // Số hóa đơn VAT (8 số)
  vatInvoiceDate   DateTime? @map("vat_invoice_date") @db.Date
  vatInvoiceSeries String? @map("vat_invoice_series") @db.VarChar(20)  // Ký hiệu hóa đơn

  notes              String? @db.Text
  paymentInstructions String? @map("payment_instructions") @db.Text

  sentAt     DateTime? @map("sent_at")
  viewedAt   DateTime? @map("viewed_at")
  cancelledAt DateTime? @map("cancelled_at")
  cancelReason String? @map("cancel_reason") @db.Text

  createdByUserId String? @map("created_by_user_id") @db.VarChar(30)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  client    Client    @relation(fields: [clientId], references: [id], onDelete: Restrict)
  contract  Contract? @relation(fields: [contractId], references: [id], onDelete: SetNull)
  project   Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  createdByUser User? @relation("InvoiceCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  items      InvoiceItem[]
  payments   ClientPayment[]
  milestones ProjectMilestone[]  // Milestone nào gắn với hóa đơn này

  @@index([clientId, status])
  @@index([contractId])
  @@index([projectId])
  @@index([dueDate, status])
  @@index([status])
  @@map("invoices")
}

// [NEW] Chi tiết từng dòng trong hóa đơn
model InvoiceItem {
  id          String @id @default(cuid()) @db.VarChar(30)
  invoiceId   String @map("invoice_id") @db.VarChar(30)

  description  String  @db.VarChar(500)        // Mô tả dịch vụ / hàng hóa
  quantity     Decimal @db.Decimal(10, 2)       // Số lượng
  unit         String? @db.VarChar(50)          // Đơn vị (giờ, ngày, lần, cái...)
  unitPrice    Decimal @map("unit_price") @db.Decimal(18, 2) // Đơn giá
  amount       Decimal @db.Decimal(18, 2)        // Thành tiền = quantity * unitPrice
  taxRate      Decimal @default(0.1) @map("tax_rate") @db.Decimal(4, 2)
  taxAmount    Decimal @map("tax_amount") @db.Decimal(18, 2)
  totalAmount  Decimal @map("total_amount") @db.Decimal(18, 2)
  displayOrder Int     @default(0) @map("display_order")
  notes        String? @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("invoice_items")
}

// [NEW] Thanh toán nhận từ khách hàng
model ClientPayment {
  id          String @id @default(cuid()) @db.VarChar(30)
  clientId    String @map("client_id") @db.VarChar(30)
  contractId  String? @map("contract_id") @db.VarChar(30)
  invoiceId   String? @map("invoice_id") @db.VarChar(30)   // Nullable: thanh toán có thể không gắn với hóa đơn cụ thể

  paymentCode     String  @unique @map("payment_code") @db.VarChar(50)  // Mã biên lai nội bộ
  amount          Decimal @db.Decimal(18, 2)
  currency        String  @default("VND") @db.VarChar(10)
  exchangeRate    Decimal @default(1) @map("exchange_rate") @db.Decimal(18, 6) // Tỷ giá nếu ngoại tệ
  amountInVnd     Decimal @map("amount_in_vnd") @db.Decimal(18, 2)     // Quy đổi VND

  paymentDate     DateTime @map("payment_date") @db.Date
  paymentMethod   PaymentMethod @map("payment_method")
  referenceNumber String?  @map("reference_number") @db.VarChar(191)   // Số tham chiếu ngân hàng
  status          ClientPaymentStatus @default(COMPLETED)

  // Tài khoản nhận tiền
  receivedBankName    String? @map("received_bank_name") @db.VarChar(191)
  receivedAccountNumber String? @map("received_account_number") @db.VarChar(100)

  notes            String?  @db.Text
  confirmedByUserId String? @map("confirmed_by_user_id") @db.VarChar(30)
  confirmedAt      DateTime? @map("confirmed_at")
  receiptUrl       String? @map("receipt_url") @db.VarChar(2048) // Biên lai

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  client         Client    @relation(fields: [clientId], references: [id], onDelete: Restrict)
  contract       Contract? @relation(fields: [contractId], references: [id], onDelete: SetNull)
  invoice        Invoice?  @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  confirmedByUser User?    @relation("PaymentConfirmedBy", fields: [confirmedByUserId], references: [id], onDelete: SetNull)

  @@index([clientId, status])
  @@index([contractId])
  @@index([invoiceId])
  @@index([paymentDate])
  @@map("client_payments")
}

// [NEW] Tài liệu liên quan đến khách hàng
model ClientDocument {
  id          String @id @default(cuid()) @db.VarChar(30)
  clientId    String @map("client_id") @db.VarChar(30)

  documentType String  @map("document_type") @db.VarChar(50) // "NDA", "PROPOSAL", "REPORT", "OTHER"
  title        String  @db.VarChar(255)
  description  String? @db.Text
  fileUrl      String  @map("file_url") @db.VarChar(2048)
  fileSize     Int?    @map("file_size")   // bytes
  mimeType     String? @map("mime_type") @db.VarChar(100)

  uploadedByUserId String? @map("uploaded_by_user_id") @db.VarChar(30)
  isConfidential   Boolean @default(false) @map("is_confidential") // Tài liệu mật

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  client         Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  uploadedByUser User?  @relation("DocumentUploadedBy", fields: [uploadedByUserId], references: [id], onDelete: SetNull)

  @@index([clientId, documentType])
  @@index([uploadedByUserId])
  @@map("client_documents")
}

// ╔══════════════════════════════════════════════════════════╗
// ║               AUTH & USER MANAGEMENT                    ║
// ╚══════════════════════════════════════════════════════════╝

model User {
  id                 String        @id @default(cuid()) @db.VarChar(30)
  employeeId         String?       @unique @map("employee_id") @db.VarChar(30)
  email              String        @unique @db.VarChar(191)
  passwordHash       String?       @map("password_hash") @db.VarChar(255)
  fullName           String?       @map("full_name") @db.VarChar(191)
  avatarUrl          String?       @map("avatar_url") @db.VarChar(2048)
  accountStatus      AccountStatus @default(PENDING) @map("account_status")
  mustChangePassword Boolean       @default(false) @map("must_change_password")
  lastLoginAt        DateTime?     @map("last_login_at")
  failedLoginCount   Int           @default(0) @map("failed_login_count")
  lockedUntil        DateTime?     @map("locked_until")
  isActive           Boolean       @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  employee   Employee? @relation("EmployeeUser", fields: [employeeId], references: [id], onDelete: SetNull)
  userRoles  UserRole[]
  authTokens AuthToken[]
  sessions   UserSession[]

  auditLogs             AuditLog[]     @relation("AuditActor")
  receivedNotifications Notification[] @relation("NotificationRecipient")
  sentNotifications     Notification[] @relation("NotificationSender")

  employeesCreated Employee[] @relation("EmployeeCreatedBy")
  employeesUpdated Employee[] @relation("EmployeeUpdatedBy")

  payrollAdjustmentsCreated  PayrollAdjustment[] @relation("PayrollAdjustmentCreatedBy")
  payrollAdjustmentsApproved PayrollAdjustment[] @relation("PayrollAdjustmentApprovedBy")
  payrollPeriodsApproved     PayrollPeriod[]     @relation("PayrollPeriodApprover")   // [NEW]

  // Client domain [NEW]
  contractsSigned    Contract[]      @relation("ContractSignedBy")
  invoicesCreated    Invoice[]       @relation("InvoiceCreatedBy")
  paymentsConfirmed  ClientPayment[] @relation("PaymentConfirmedBy")
  documentsUploaded  ClientDocument[] @relation("DocumentUploadedBy")
  expensesApproved   ProjectExpense[] @relation("ExpenseApprover") // [NEW]

  @@index([accountStatus, isActive])
  @@index([employeeId])
  @@map("users")
}

model Role {
  id          String  @id @default(cuid()) @db.VarChar(30)
  code        String  @unique @db.VarChar(50)
  name        String  @unique @db.VarChar(100)
  description String? @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  userRoles UserRole[]

  @@map("roles")
}

model UserRole {
  id     String @id @default(cuid()) @db.VarChar(30)
  userId String @map("user_id") @db.VarChar(30)
  roleId String @map("role_id") @db.VarChar(30)

  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([roleId])
  @@map("user_roles")
}

model AuthToken {
  id        String        @id @default(cuid()) @db.VarChar(30)
  userId    String        @map("user_id") @db.VarChar(30)
  tokenType AuthTokenType @map("token_type")
  tokenHash String        @unique @map("token_hash") @db.VarChar(255)
  expiresAt DateTime      @map("expires_at")
  usedAt    DateTime?     @map("used_at")
  createdAt DateTime      @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, tokenType])
  @@index([expiresAt])
  @@map("auth_tokens")
}

model UserSession {
  id               String    @id @default(cuid()) @db.VarChar(30)
  userId           String    @map("user_id") @db.VarChar(30)
  refreshTokenHash String    @unique @map("refresh_token_hash") @db.VarChar(255)
  ipAddress        String?   @map("ip_address") @db.VarChar(64)
  userAgent        String?   @map("user_agent") @db.VarChar(1024)
  expiresAt        DateTime  @map("expires_at")
  revokedAt        DateTime? @map("revoked_at")
  createdAt        DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@map("user_sessions")
}

// ╔══════════════════════════════════════════════════════════╗
// ║               NOTIFICATION & AUDIT                     ║
// ╚══════════════════════════════════════════════════════════╝

model Notification {
  id              String           @id @default(cuid()) @db.VarChar(30)
  recipientUserId String           @map("recipient_user_id") @db.VarChar(30)
  senderUserId    String?          @map("sender_user_id") @db.VarChar(30)
  type            NotificationType
  title           String           @db.VarChar(191)
  message         String           @db.Text
  relatedEntityType String?        @map("related_entity_type") @db.VarChar(50)
  relatedEntityId   String?        @map("related_entity_id") @db.VarChar(30)
  actionUrl         String?        @map("action_url") @db.VarChar(2048) // [NEW] Deep link
  isRead          Boolean          @default(false) @map("is_read")
  readAt          DateTime?        @map("read_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  recipientUser User  @relation("NotificationRecipient", fields: [recipientUserId], references: [id], onDelete: Cascade)
  senderUser    User? @relation("NotificationSender", fields: [senderUserId], references: [id], onDelete: SetNull)

  @@index([recipientUserId, isRead])
  @@index([type])
  @@index([senderUserId])
  @@map("notifications")
}

model AuditLog {
  id          String          @id @default(cuid()) @db.VarChar(30)
  entityType  AuditEntityType @map("entity_type")
  entityId    String          @map("entity_id") @db.VarChar(30)
  actionType  AuditActionType @map("action_type")
  actorUserId String?         @map("actor_user_id") @db.VarChar(30)

  description String? @db.Text
  oldValues   Json?   @map("old_values")
  newValues   Json?   @map("new_values")
  metadata    Json?

  ipAddress String? @map("ip_address") @db.VarChar(64)
  userAgent String? @map("user_agent") @db.VarChar(1024)

  createdAt DateTime @default(now()) @map("created_at")

  actorUser User? @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([createdAt])
  @@index([actorUserId])
  @@map("audit_logs")
}
