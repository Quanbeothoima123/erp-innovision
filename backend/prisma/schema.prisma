// ============================================================
//  schema.prisma — v2.0  (HR + Payroll + Client Management)
//  Upgraded từ v1 với các bổ sung:
//  [NEW]  Quản lý khách hàng / nhà đầu tư (Client domain)
//  [NEW]  Hợp đồng & hóa đơn (Contract / Invoice)
//  [NEW]  Thanh toán khách hàng (ClientPayment)
//  [IMPROVED] Lương – thêm OT, thuế, bảo hiểm, số dư phép
//  [IMPROVED] Chấm công – thêm ca, đi muộn, OT phút
//  [IMPROVED] Dự án – link sang Client & Contract
// ============================================================

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

