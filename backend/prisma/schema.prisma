generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Department {
  id          String   @id @default(cuid()) @db.VarChar(30)
  name        String   @unique
  description String?  @db.Text
  headUserId  String?  @map("head_user_id") @db.VarChar(30)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  headUser    User?    @relation("DepartmentHead", fields: [headUserId], references: [id])
  members     User[]   @relation("UserDepartment")

  @@index([headUserId])
  @@index([isActive])
  @@map("departments")
}

model JobTitle {
  id          String   @id @default(cuid()) @db.VarChar(30)
  code        String?  @unique @db.VarChar(50)
  name        String   @unique
  description String?  @db.Text
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  users       User[]   @relation("UserJobTitle")

  @@index([isActive])
  @@map("job_titles")
}

model User {
  id                     String                  @id @default(cuid()) @db.VarChar(30)
  userCode               String?                 @unique @map("user_code") @db.VarChar(50)
  email                  String                  @unique
  passwordHash           String?                 @map("password_hash") @db.VarChar(255)
  fullName               String                  @map("full_name")
  phoneNumber            String?                 @map("phone_number") @db.VarChar(30)
  avatarUrl              String?                 @map("avatar_url") @db.VarChar(2048)
  departmentId           String?                 @map("department_id") @db.VarChar(30)
  jobTitleId             String?                 @map("job_title_id") @db.VarChar(30)
  managerId              String?                 @map("manager_id") @db.VarChar(30)
  hireDate               DateTime?               @map("hire_date") @db.Date
  employmentStatus       EmploymentStatus        @default(PROBATION) @map("employment_status")
  accountStatus          AccountStatus           @default(PENDING) @map("account_status")
  mustChangePassword     Boolean                 @default(true) @map("must_change_password")
  lastLoginAt            DateTime?               @map("last_login_at")
  failedLoginCount       Int                     @default(0) @map("failed_login_count")
  lockedUntil            DateTime?               @map("locked_until")
  terminatedAt           DateTime?               @map("terminated_at")
  terminationReason      String?                 @map("termination_reason") @db.Text
  createdByUserId        String?                 @map("created_by_user_id") @db.VarChar(30)
  adminNotes             String?                 @map("admin_notes") @db.Text
  createdAt              DateTime                @default(now()) @map("created_at")
  updatedAt              DateTime                @updatedAt @map("updated_at")
  attendanceAdjusted     AttendanceRecord[]      @relation("AttendanceAdjustedBy")
  attendanceRecords      AttendanceRecord[]      @relation("AttendanceUser")
  attendanceReviewed     AttendanceRequest[]     @relation("AttendanceReviewer")
  attendanceRequests     AttendanceRequest[]     @relation("AttendanceRequester")
  auditLogs              AuditLog[]              @relation("AuditActor")
  authTokens             AuthToken[]
  documentsUploaded      ClientDocument[]        @relation("DocumentUploadedBy")
  paymentsConfirmed      ClientPayment[]         @relation("PaymentConfirmedBy")
  managedClients         Client[]                @relation("ClientAccountManager")
  contractsSigned        Contract[]              @relation("ContractSignedBy")
  headedDepartments      Department[]            @relation("DepartmentHead")
  invoicesCreated        Invoice[]               @relation("InvoiceCreatedBy")
  leaveBalances          LeaveBalance[]
  leaveApprovals         LeaveRequestApproval[]  @relation("LeaveApprover")
  leaveRequests          LeaveRequest[]          @relation("LeaveRequester")
  receivedNotifications  Notification[]          @relation("NotificationRecipient")
  sentNotifications      Notification[]          @relation("NotificationSender")
  overtimeApprovals      OvertimeRequest[]       @relation("OvertimeApprover")
  overtimeRequests       OvertimeRequest[]       @relation("OvertimeRequester")
  payrollAdjApproved     PayrollAdjustment[]     @relation("AdjustmentApprovedBy")
  payrollAdjCreated      PayrollAdjustment[]     @relation("AdjustmentCreatedBy")
  payrollAdjustments     PayrollAdjustment[]     @relation("AdjustmentEmployee")
  payrollPeriodsApproved PayrollPeriod[]         @relation("PayrollPeriodApprover")
  payrollRecords         PayrollRecord[]
  expensesApproved       ProjectExpense[]        @relation("ExpenseApprover")
  projectExpenses        ProjectExpense[]        @relation("ExpenseSubmitter")
  milestoneOwnerships    ProjectMilestone[]      @relation("MilestoneOwner")
  managedProjects        Project[]               @relation("ProjectManager")
  compensations          UserCompensation[]
  profile                UserProfile?
  projectAssignments     UserProjectAssignment[]
  roles                  UserRole[]
  userSalaryComponents   UserSalaryComponent[]
  sessions               UserSession[]
  userWorkShifts         UserWorkShift[]
  createdBy              User?                   @relation("UserCreatedBy", fields: [createdByUserId], references: [id])
  createdUsers           User[]                  @relation("UserCreatedBy")
  department             Department?             @relation("UserDepartment", fields: [departmentId], references: [id])
  jobTitle               JobTitle?               @relation("UserJobTitle", fields: [jobTitleId], references: [id])
  manager                User?                   @relation("UserManager", fields: [managerId], references: [id])
  subordinates           User[]                  @relation("UserManager")
  createdTasks  Task[]        @relation("TaskCreator")
  assignedTasks Task[]        @relation("TaskAssignee")
  taskComments  TaskComment[] @relation("TaskCommentAuthor")
  @@index([accountStatus, employmentStatus])
  @@index([departmentId])
  @@index([managerId])
  @@index([email])
  @@index([createdByUserId], map: "users_created_by_user_id_fkey")
  @@index([jobTitleId], map: "users_job_title_id_fkey")
  @@map("users")
}

model UserProfile {
  id                    String    @id @default(cuid()) @db.VarChar(30)
  userId                String    @unique @map("user_id") @db.VarChar(30)
  dateOfBirth           DateTime? @map("date_of_birth") @db.Date
  gender                Gender?
  placeOfBirth          String?   @map("place_of_birth")
  nationality           String?   @default("Vietnamese") @db.VarChar(100)
  ethnicity             String?   @db.VarChar(100)
  permanentAddress      String?   @map("permanent_address") @db.VarChar(500)
  currentAddress        String?   @map("current_address") @db.VarChar(500)
  city                  String?   @db.VarChar(100)
  province              String?   @db.VarChar(100)
  nationalIdNumber      String?   @unique @map("national_id_number") @db.VarChar(50)
  nationalIdIssueDate   DateTime? @map("national_id_issue_date") @db.Date
  nationalIdIssuePlace  String?   @map("national_id_issue_place")
  passportNumber        String?   @map("passport_number") @db.VarChar(50)
  passportExpiry        DateTime? @map("passport_expiry") @db.Date
  taxCode               String?   @unique @map("tax_code") @db.VarChar(50)
  socialInsuranceNumber String?   @unique @map("social_insurance_number") @db.VarChar(50)
  healthInsuranceNumber String?   @map("health_insurance_number") @db.VarChar(50)
  healthInsuranceExpiry DateTime? @map("health_insurance_expiry") @db.Date
  bankName              String?   @map("bank_name")
  bankBranch            String?   @map("bank_branch")
  bankAccountNumber     String?   @map("bank_account_number") @db.VarChar(100)
  bankAccountHolder     String?   @map("bank_account_holder")
  emergencyContactName  String?   @map("emergency_contact_name")
  emergencyContactPhone String?   @map("emergency_contact_phone") @db.VarChar(30)
  emergencyContactRel   String?   @map("emergency_contact_rel") @db.VarChar(100)
  dependantCount        Int       @default(0) @map("dependant_count")
  educationLevel        String?   @map("education_level") @db.VarChar(100)
  educationMajor        String?   @map("education_major")
  university            String?
  notes                 String?   @db.Text
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model Role {
  id          String     @id @default(cuid()) @db.VarChar(30)
  code        String     @unique @db.VarChar(50)
  name        String     @unique @db.VarChar(100)
  description String?    @db.Text
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  userRoles   UserRole[]

  @@map("roles")
}

model UserRole {
  id        String   @id @default(cuid()) @db.VarChar(30)
  userId    String   @map("user_id") @db.VarChar(30)
  roleId    String   @map("role_id") @db.VarChar(30)
  createdAt DateTime @default(now()) @map("created_at")
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([roleId])
  @@map("user_roles")
}

model AuthToken {
  id        String        @id @default(cuid()) @db.VarChar(30)
  userId    String        @map("user_id") @db.VarChar(30)
  tokenType AuthTokenType @map("token_type")
  tokenHash String        @unique @map("token_hash") @db.VarChar(255)
  expiresAt DateTime      @map("expires_at")
  usedAt    DateTime?     @map("used_at")
  createdAt DateTime      @default(now()) @map("created_at")
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, tokenType])
  @@index([expiresAt])
  @@map("auth_tokens")
}

model UserSession {
  id               String    @id @default(cuid()) @db.VarChar(30)
  userId           String    @map("user_id") @db.VarChar(30)
  refreshTokenHash String    @unique @map("refresh_token_hash") @db.VarChar(255)
  ipAddress        String?   @map("ip_address") @db.VarChar(64)
  userAgent        String?   @map("user_agent") @db.VarChar(1024)
  expiresAt        DateTime  @map("expires_at")
  revokedAt        DateTime? @map("revoked_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@map("user_sessions")
}

model LeaveType {
  id               String         @id @default(cuid()) @db.VarChar(30)
  code             String         @unique @db.VarChar(50)
  name             String         @unique
  description      String?        @db.Text
  isPaid           Boolean        @default(true) @map("is_paid")
  isActive         Boolean        @default(true) @map("is_active")
  maxDaysPerYear   Decimal?       @map("max_days_per_year") @db.Decimal(5, 2)
  requiresDocument Boolean        @default(false) @map("requires_document")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")
  leaveBalances    LeaveBalance[]
  leaveRequests    LeaveRequest[]

  @@index([isActive])
  @@map("leave_types")
}

model LeaveBalance {
  id            String    @id @default(cuid()) @db.VarChar(30)
  userId        String    @map("user_id") @db.VarChar(30)
  leaveTypeId   String    @map("leave_type_id") @db.VarChar(30)
  year          Int       @db.UnsignedSmallInt
  entitledDays  Decimal   @map("entitled_days") @db.Decimal(5, 2)
  carriedDays   Decimal   @default(0.00) @map("carried_days") @db.Decimal(5, 2)
  adjustedDays  Decimal   @default(0.00) @map("adjusted_days") @db.Decimal(5, 2)
  usedDays      Decimal   @default(0.00) @map("used_days") @db.Decimal(5, 2)
  pendingDays   Decimal   @default(0.00) @map("pending_days") @db.Decimal(5, 2)
  remainingDays Decimal   @default(0.00) @map("remaining_days") @db.Decimal(5, 2)
  notes         String?   @db.Text
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  leaveType     LeaveType @relation(fields: [leaveTypeId], references: [id])
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, leaveTypeId, year])
  @@index([userId, year])
  @@index([leaveTypeId], map: "leave_balances_leave_type_id_fkey")
  @@map("leave_balances")
}

model LeaveRequest {
  id              String                 @id @default(cuid()) @db.VarChar(30)
  userId          String                 @map("user_id") @db.VarChar(30)
  leaveTypeId     String                 @map("leave_type_id") @db.VarChar(30)
  startDate       DateTime               @map("start_date") @db.Date
  endDate         DateTime               @map("end_date") @db.Date
  totalDays       Decimal                @map("total_days") @db.Decimal(5, 2)
  isHalfDay       Boolean                @default(false) @map("is_half_day")
  halfDayPeriod   String?                @map("half_day_period") @db.VarChar(10)
  reason          String?                @db.Text
  documentUrl     String?                @map("document_url") @db.VarChar(2048)
  status          LeaveRequestStatus     @default(PENDING)
  currentStep     ApprovalStepType?      @map("current_step")
  submittedAt     DateTime               @default(now()) @map("submitted_at")
  finalApprovedAt DateTime?              @map("final_approved_at")
  rejectedAt      DateTime?              @map("rejected_at")
  rejectionReason String?                @map("rejection_reason") @db.Text
  cancelledAt     DateTime?              @map("cancelled_at")
  cancelReason    String?                @map("cancel_reason") @db.Text
  createdAt       DateTime               @default(now()) @map("created_at")
  updatedAt       DateTime               @updatedAt @map("updated_at")
  approvals       LeaveRequestApproval[]
  leaveType       LeaveType              @relation(fields: [leaveTypeId], references: [id])
  user            User                   @relation("LeaveRequester", fields: [userId], references: [id])

  @@index([userId, status])
  @@index([leaveTypeId])
  @@index([startDate, endDate])
  @@map("leave_requests")
}

model LeaveRequestApproval {
  id             String           @id @default(cuid()) @db.VarChar(30)
  leaveRequestId String           @map("leave_request_id") @db.VarChar(30)
  approverUserId String           @map("approver_user_id") @db.VarChar(30)
  stepType       ApprovalStepType @map("step_type")
  stepOrder      Int              @map("step_order")
  status         ApprovalStatus   @default(PENDING)
  comment        String?          @db.Text
  actionAt       DateTime?        @map("action_at")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")
  approver       User             @relation("LeaveApprover", fields: [approverUserId], references: [id])
  leaveRequest   LeaveRequest     @relation(fields: [leaveRequestId], references: [id], onDelete: Cascade)

  @@unique([leaveRequestId, stepType])
  @@unique([leaveRequestId, stepOrder])
  @@index([approverUserId, status])
  @@map("leave_request_approvals")
}

model Holiday {
  id                 String   @id @default(cuid()) @db.VarChar(30)
  name               String
  date               DateTime @unique @db.Date
  year               Int      @db.UnsignedSmallInt
  isRecurring        Boolean  @default(false) @map("is_recurring")
  description        String?  @db.Text
  overtimeMultiplier Decimal  @default(3.0) @map("overtime_multiplier") @db.Decimal(3, 1)
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@index([year])
  @@map("holidays")
}

model WorkShift {
  id                   String              @id @default(cuid()) @db.VarChar(30)
  code                 String              @unique @db.VarChar(50)
  name                 String              @unique
  shiftType            ShiftType           @map("shift_type")
  startTime            String              @map("start_time") @db.VarChar(5)
  endTime              String              @map("end_time") @db.VarChar(5)
  breakMinutes         Int                 @default(60) @map("break_minutes")
  workMinutes          Int                 @map("work_minutes")
  isNightShift         Boolean             @default(false) @map("is_night_shift")
  overtimeAfterMinutes Int                 @default(0) @map("overtime_after_minutes")
  isActive             Boolean             @default(true) @map("is_active")
  createdAt            DateTime            @default(now()) @map("created_at")
  updatedAt            DateTime            @updatedAt @map("updated_at")
  attendanceRecords    AttendanceRecord[]
  attendanceRequests   AttendanceRequest[]
  userWorkShifts       UserWorkShift[]

  @@index([isActive])
  @@map("work_shifts")
}

model AttendanceRequest {
  id                      String                  @id @default(cuid()) @db.VarChar(30)
  userId                  String                  @map("user_id") @db.VarChar(30)
  reviewerId              String?                 @map("reviewer_id") @db.VarChar(30)
  requestType             AttendanceRequestType   @map("request_type")
  requestedAt             DateTime                @map("requested_at")
  workDate                DateTime                @map("work_date") @db.Date
  shiftId                 String?                 @map("shift_id") @db.VarChar(30)
  isRemoteWork            Boolean                 @default(false) @map("is_remote_work")
  note                    String?                 @db.Text
  imageUrl                String?                 @map("image_url") @db.VarChar(2048)
  status                  AttendanceRequestStatus @default(PENDING)
  reviewedAt              DateTime?               @map("reviewed_at")
  rejectReason            String?                 @map("reject_reason") @db.Text
  createdAt               DateTime                @default(now()) @map("created_at")
  updatedAt               DateTime                @updatedAt @map("updated_at")
  generatedCheckinRecord  AttendanceRecord?       @relation("SourceCheckinRequest")
  generatedCheckoutRecord AttendanceRecord?       @relation("SourceCheckoutRequest")
  reviewer                User?                   @relation("AttendanceReviewer", fields: [reviewerId], references: [id])
  shift                   WorkShift?              @relation(fields: [shiftId], references: [id])
  user                    User                    @relation("AttendanceRequester", fields: [userId], references: [id])

  @@index([userId, status])
  @@index([workDate])
  @@index([requestType, status])
  @@index([reviewerId], map: "attendance_requests_reviewer_id_fkey")
  @@index([shiftId], map: "attendance_requests_shift_id_fkey")
  @@map("attendance_requests")
}

model AttendanceRecord {
  id                      String             @id @default(cuid()) @db.VarChar(30)
  userId                  String             @map("user_id") @db.VarChar(30)
  shiftId                 String?            @map("shift_id") @db.VarChar(30)
  workDate                DateTime           @map("work_date") @db.Date
  checkInAt               DateTime?          @map("check_in_at")
  checkOutAt              DateTime?          @map("check_out_at")
  totalWorkMinutes        Int?               @map("total_work_minutes")
  lateMinutes             Int                @default(0) @map("late_minutes")
  earlyLeaveMinutes       Int                @default(0) @map("early_leave_minutes")
  overtimeMinutes         Int                @default(0) @map("overtime_minutes")
  overtimeApprovedMinutes Int                @default(0) @map("overtime_approved_minutes")
  isHolidayWork           Boolean            @default(false) @map("is_holiday_work")
  isWeekendWork           Boolean            @default(false) @map("is_weekend_work")
  isRemoteWork            Boolean            @default(false) @map("is_remote_work")
  status                  AttendanceStatus   @default(PRESENT)
  note                    String?            @db.Text
  sourceCheckinRequestId  String?            @unique @map("source_checkin_request_id") @db.VarChar(30)
  sourceCheckoutRequestId String?            @unique @map("source_checkout_request_id") @db.VarChar(30)
  adjustedByUserId        String?            @map("adjusted_by_user_id") @db.VarChar(30)
  createdAt               DateTime           @default(now()) @map("created_at")
  updatedAt               DateTime           @updatedAt @map("updated_at")
  adjustedBy              User?              @relation("AttendanceAdjustedBy", fields: [adjustedByUserId], references: [id])
  shift                   WorkShift?         @relation(fields: [shiftId], references: [id])
  sourceCheckin           AttendanceRequest? @relation("SourceCheckinRequest", fields: [sourceCheckinRequestId], references: [id])
  sourceCheckout          AttendanceRequest? @relation("SourceCheckoutRequest", fields: [sourceCheckoutRequestId], references: [id])
  user                    User               @relation("AttendanceUser", fields: [userId], references: [id])

  @@unique([userId, workDate])
  @@index([workDate])
  @@index([userId, status])
  @@index([adjustedByUserId], map: "attendance_records_adjusted_by_user_id_fkey")
  @@index([shiftId], map: "attendance_records_shift_id_fkey")
  @@map("attendance_records")
}

model OvertimeRequest {
  id             String                @id @default(cuid()) @db.VarChar(30)
  userId         String                @map("user_id") @db.VarChar(30)
  approverUserId String?               @map("approver_user_id") @db.VarChar(30)
  workDate       DateTime              @map("work_date") @db.Date
  startTime      String                @map("start_time") @db.VarChar(5)
  endTime        String                @map("end_time") @db.VarChar(5)
  plannedMinutes Int                   @map("planned_minutes")
  actualMinutes  Int?                  @map("actual_minutes")
  isHoliday      Boolean               @default(false) @map("is_holiday")
  isWeekend      Boolean               @default(false) @map("is_weekend")
  reason         String?               @db.Text
  status         OvertimeRequestStatus @default(PENDING)
  submittedAt    DateTime              @default(now()) @map("submitted_at")
  actionAt       DateTime?             @map("action_at")
  comment        String?               @db.Text
  createdAt      DateTime              @default(now()) @map("created_at")
  updatedAt      DateTime              @updatedAt @map("updated_at")
  approver       User?                 @relation("OvertimeApprover", fields: [approverUserId], references: [id])
  user           User                  @relation("OvertimeRequester", fields: [userId], references: [id])

  @@index([userId, status])
  @@index([workDate])
  @@index([approverUserId])
  @@map("overtime_requests")
}

model Project {
  id                   String                  @id @default(cuid()) @db.VarChar(30)
  projectCode          String?                 @unique @map("project_code") @db.VarChar(50)
  projectName          String                  @map("project_name")
  description          String?                 @db.Text
  projectManagerUserId String?                 @map("project_manager_user_id") @db.VarChar(30)
  clientId             String?                 @map("client_id") @db.VarChar(30)
  contractId           String?                 @map("contract_id") @db.VarChar(30)
  status               ProjectStatus           @default(PLANNING)
  priority             ProjectPriority?
  healthStatus         ProjectHealthStatus?    @map("health_status")
  progressPercent      Decimal                 @default(0.00) @map("progress_percent") @db.Decimal(5, 2)
  startDate            DateTime?               @map("start_date") @db.Date
  endDate              DateTime?               @map("end_date") @db.Date
  actualEndDate        DateTime?               @map("actual_end_date") @db.Date
  budgetAmount         Decimal?                @map("budget_amount") @db.Decimal(18, 2)
  spentAmount          Decimal                 @default(0.00) @map("spent_amount") @db.Decimal(18, 2)
  currency             String                  @default("VND") @db.VarChar(10)
  contractValue        Decimal?                @map("contract_value") @db.Decimal(18, 2)
  invoicedAmount       Decimal                 @default(0.00) @map("invoiced_amount") @db.Decimal(18, 2)
  receivedAmount       Decimal                 @default(0.00) @map("received_amount") @db.Decimal(18, 2)
  closedAt             DateTime?               @map("closed_at")
  closureNote          String?                 @map("closure_note") @db.Text
  createdAt            DateTime                @default(now()) @map("created_at")
  updatedAt            DateTime                @updatedAt @map("updated_at")
  invoices             Invoice[]
  expenses             ProjectExpense[]
  milestones           ProjectMilestone[]
  client               Client?                 @relation(fields: [clientId], references: [id])
  contract             Contract?               @relation("ProjectContract", fields: [contractId], references: [id])
  projectManager       User?                   @relation("ProjectManager", fields: [projectManagerUserId], references: [id])
  assignments          UserProjectAssignment[]
  tasks Task[]
  @@index([projectManagerUserId])
  @@index([clientId])
  @@index([contractId])
  @@index([status])
  @@map("projects")
}

model UserProjectAssignment {
  id                String                  @id @default(cuid()) @db.VarChar(30)
  userId            String                  @map("user_id") @db.VarChar(30)
  projectId         String                  @map("project_id") @db.VarChar(30)
  roleInProject     String?                 @map("role_in_project") @db.VarChar(100)
  allocationPercent Decimal?                @map("allocation_percent") @db.Decimal(5, 2)
  hourlyRate        Decimal?                @map("hourly_rate") @db.Decimal(18, 2)
  joinedAt          DateTime                @map("joined_at") @db.Date
  leftAt            DateTime?               @map("left_at") @db.Date
  status            ProjectAssignmentStatus @default(ACTIVE)
  isBillable        Boolean                 @default(false) @map("is_billable")
  notes             String?                 @db.Text
  createdAt         DateTime                @default(now()) @map("created_at")
  updatedAt         DateTime                @updatedAt @map("updated_at")
  project           Project                 @relation(fields: [projectId], references: [id])
  user              User                    @relation(fields: [userId], references: [id])

  @@unique([userId, projectId, joinedAt])
  @@index([userId, status])
  @@index([projectId, status])
  @@map("user_project_assignments")
}

