  receivedBankName      String?             @map("received_bank_name")
  receivedAccountNumber String?             @map("received_account_number") @db.VarChar(100)
  notes                 String?             @db.Text
  confirmedByUserId     String?             @map("confirmed_by_user_id") @db.VarChar(30)
  confirmedAt           DateTime?           @map("confirmed_at")
  receiptUrl            String?             @map("receipt_url") @db.VarChar(2048)
  createdAt             DateTime            @default(now()) @map("created_at")
  updatedAt             DateTime            @updatedAt @map("updated_at")
  client                Client              @relation(fields: [clientId], references: [id])
  confirmedByUser       User?               @relation("PaymentConfirmedBy", fields: [confirmedByUserId], references: [id])
  contract              Contract?           @relation(fields: [contractId], references: [id])
  invoice               Invoice?            @relation(fields: [invoiceId], references: [id])

  @@index([clientId, status])
  @@index([contractId])
  @@index([invoiceId])
  @@index([paymentDate])
  @@index([confirmedByUserId], map: "client_payments_confirmed_by_user_id_fkey")
  @@map("client_payments")
}

model ClientDocument {
  id               String   @id @default(cuid()) @db.VarChar(30)
  clientId         String   @map("client_id") @db.VarChar(30)
  documentType     String   @map("document_type") @db.VarChar(50)
  title            String   @db.VarChar(255)
  description      String?  @db.Text
  fileUrl          String   @map("file_url") @db.VarChar(2048)
  fileSize         Int?     @map("file_size")
  mimeType         String?  @map("mime_type") @db.VarChar(100)
  uploadedByUserId String?  @map("uploaded_by_user_id") @db.VarChar(30)
  isConfidential   Boolean  @default(false) @map("is_confidential")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  client           Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  uploadedByUser   User?    @relation("DocumentUploadedBy", fields: [uploadedByUserId], references: [id])

  @@index([clientId, documentType])
  @@index([uploadedByUserId], map: "client_documents_uploaded_by_user_id_fkey")
  @@map("client_documents")
}

model UserWorkShift {
  id            String    @id @default(cuid()) @db.VarChar(30)
  userId        String    @map("user_id") @db.VarChar(30)
  shiftId       String    @map("shift_id") @db.VarChar(30)
  dayOfWeek     Int?      @map("day_of_week") @db.UnsignedTinyInt
  effectiveFrom DateTime  @map("effective_from") @db.Date
  effectiveTo   DateTime? @map("effective_to") @db.Date
  isActive      Boolean   @default(true) @map("is_active")
  notes         String?   @db.Text
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  shift         WorkShift @relation(fields: [shiftId], references: [id])
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, shiftId, dayOfWeek, effectiveFrom])
  @@index([userId, isActive])
  @@index([shiftId])
  @@map("user_work_shifts")
}

model SystemConfig {
  id          String   @id @default(cuid()) @db.VarChar(30)
  key         String   @unique @db.VarChar(100)
  value       String   @db.Text
  description String?  @db.VarChar(500)
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("system_configs")
}

model Notification {
  id                String           @id @default(cuid()) @db.VarChar(30)
  recipientUserId   String           @map("recipient_user_id") @db.VarChar(30)
  senderUserId      String?          @map("sender_user_id") @db.VarChar(30)
  type              NotificationType
  title             String
  message           String           @db.Text
  relatedEntityType String?          @map("related_entity_type") @db.VarChar(50)
  relatedEntityId   String?          @map("related_entity_id") @db.VarChar(30)
  actionUrl         String?          @map("action_url") @db.VarChar(2048)
  isRead            Boolean          @default(false) @map("is_read")
  readAt            DateTime?        @map("read_at")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")
  recipientUser     User             @relation("NotificationRecipient", fields: [recipientUserId], references: [id], onDelete: Cascade)
  senderUser        User?            @relation("NotificationSender", fields: [senderUserId], references: [id])

  @@index([recipientUserId, isRead])
  @@index([recipientUserId, type])
  @@index([type])
  @@index([senderUserId], map: "notifications_sender_user_id_fkey")
  @@map("notifications")
}

model AuditLog {
  id          String          @id @default(cuid()) @db.VarChar(30)
  entityType  AuditEntityType @map("entity_type")
  entityId    String          @map("entity_id") @db.VarChar(30)
  actionType  AuditActionType @map("action_type")
  actorUserId String?         @map("actor_user_id") @db.VarChar(30)
  description String?         @db.Text
  oldValues   Json?           @map("old_values")
  newValues   Json?           @map("new_values")
  metadata    Json?
  ipAddress   String?         @map("ip_address") @db.VarChar(64)
  userAgent   String?         @map("user_agent") @db.VarChar(1024)
  createdAt   DateTime        @default(now()) @map("created_at")
  actorUser   User?           @relation("AuditActor", fields: [actorUserId], references: [id])

  @@index([entityType, entityId])
  @@index([createdAt])
  @@index([actorUserId])
  @@map("audit_logs")
}

