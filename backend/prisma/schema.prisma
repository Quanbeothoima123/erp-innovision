enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
  CANCELLED
}

model Task {
  id               String       @id @default(cuid()) @db.VarChar(30)
  title            String       @db.VarChar(255)
  description      String?      @db.Text

  // Deadline và độ ưu tiên
  deadline         DateTime?
  priority         TaskPriority @default(MEDIUM)
  status           TaskStatus   @default(TODO)

  // Ghi chú nguồn gốc task: "Email KH Acme 28/3", "Họp sprint"...
  sourceMessage    String?      @map("source_message") @db.Text

  // Dự án liên quan — nullable (task có thể không thuộc dự án nào)
  projectId        String?      @map("project_id")     @db.VarChar(30)

  // Người được giao — nullable (có thể assign sau)
  assignedToUserId String?      @map("assigned_to_user_id") @db.VarChar(30)

  // Người tạo task (ADMIN / MANAGER / direct manager)
  createdByUserId  String       @map("created_by_user_id") @db.VarChar(30)

  // Tracking effort
  estimatedHours   Decimal?     @map("estimated_hours") @db.Decimal(5, 1)
  actualHours      Decimal?     @map("actual_hours")    @db.Decimal(5, 1)

  completedAt      DateTime?    @map("completed_at")
  isActive         Boolean      @default(true)         @map("is_active")
  createdAt        DateTime     @default(now())         @map("created_at")
  updatedAt        DateTime     @updatedAt              @map("updated_at")

  // Relations
  project    Project?      @relation(fields: [projectId],        references: [id], onDelete: SetNull,  onUpdate: Cascade)
  assignedTo User?         @relation("TaskAssignee",             fields: [assignedToUserId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  createdBy  User          @relation("TaskCreator",              fields: [createdByUserId],  references: [id], onDelete: Restrict, onUpdate: Cascade)
  comments   TaskComment[]

  @@index([status, isActive],      name: "tasks_status_is_active_idx")
  @@index([assignedToUserId],      name: "tasks_assigned_to_user_id_idx")
  @@index([projectId],             name: "tasks_project_id_idx")
  @@index([createdByUserId],       name: "tasks_created_by_user_id_idx")
  @@index([deadline],              name: "tasks_deadline_idx")
  @@index([priority],              name: "tasks_priority_idx")
  @@map("tasks")
}

model TaskComment {
  id        String   @id @default(cuid()) @db.VarChar(30)
  taskId    String   @map("task_id")  @db.VarChar(30)
  userId    String   @map("user_id")  @db.VarChar(30)
  content   String   @db.Text

  // Đánh dấu khi comment bị chỉnh sửa
  isEdited  Boolean  @default(false) @map("is_edited")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  user User @relation("TaskCommentAuthor", fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([taskId], name: "task_comments_task_id_idx")
  @@map("task_comments")
}
